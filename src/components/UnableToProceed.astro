<div
	id="doses"
	class="modal fade dose-modal"
	tabindex="-1"
	aria-labelledby="exampleModalLabel"
	aria-hidden="true"
>
	<div class="modal-dialog" role="document">
		<div class="modal-content">
			<!-- <button type="button" class="btn-close" data-dismiss="modal">
				<i class="icon-cross_filled"></i>
			</button> -->

			<div class="modal-body">
				<div class="modal__text mt-0">
					<div class="d-flex flex-column align-items-center">
						<div class="modal__logo">
							<img
								class="img-fluid modal__logo__img"
								src="Themes/Thrivewellrx.Theme.Slimout/assets/img/logo-main.svg"
								alt="Logo"
							/>

							<img
								class="img-fluid"
								src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/frame-with-title-green.svg"
								alt="frame "
							/>
						</div>
					</div>

					<h5 class="site__heading-five fw-bold text-secondary"
						>Select Program</h5
					>
				</div>
				<p class="text-blue-6 text-center mb-20">
					You can select any 1 program from below list
				</p>
				<div class="dose-modal__cta mt-30">
					<button class="theme-btn theme-btn__danger">1 Month Programs</button>
					<button class="theme-btn theme-btn__danger oqtane-btn__active"
						>3 Month Programs</button
					>
				</div>
				<div class="modal__radios mt-30">
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$50</span
							>
						</label>
					</div>
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$50</span
							>
						</label>
					</div>
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$350</span
							>
						</label>
					</div>
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$350</span
							>
						</label>
					</div>
				</div>

				<div class="dose-modal__selection">
					<p class="fs-14"
						><span class="fw-bold">You have selected</span> - 0.25mg - $299
					</p>
				</div>
				<div class="modal__actions">
					<button
						class="modal__action modal__action--outline"
						data-bs-dismiss="modal"
						aria-label="Close"
						type="button"
					>
						Cancel
					</button>
					<button class="modal__action modal__action--primary" type="button">
						Confirm
					</button>
				</div>
			</div>
		</div>
	</div>
</div>
