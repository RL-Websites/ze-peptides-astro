<div class="swiper product__wrapper">
	<div class="swiper-wrapper">
		<div class="product__card product__card--purple swiper-slide">
			<div class="product__img">
				<img
					src="Themes/Thrivewellrx.Theme.Slimout/assets/img/products/product-1.png"
					alt="Product"
				/>
			</div>
			<div class="product__content">
				<h6 class="site__heading-six">Semaglutide Injection</h6>
				<p class="mb-0">Starting at $149 Monthly + </p>
				<p>$45 Physician consult</p>
				<button
					type="button"
					class="theme-btn theme-btn__light"
					data-bs-toggle="modal"
					data-bs-target="#doses">See If I Qualify</button
				>
			</div>
		</div>
		<div class="product__card product__card--pink swiper-slide">
