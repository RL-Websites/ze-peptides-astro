---
// MobileTimelineStep.astro
interface Props {
	stepNumber: number;
	title: string;
	description: string;
	imageSrc: string;
	imageAlt: string;
	isActive?: boolean;
	isLast?: boolean;
}

const {
	stepNumber,
	title,
	description,
	imageSrc,
	imageAlt,
	isLast = false,
} = Astro.props;

const dotClass = "mobile-dot";
const numberClass = "mobile-step-number";
---

<div class="mobile-timeline-step" data-observed>
	<div class="d-flex items-start gap-4">
		<div
			class="d-flex flex-column align-items-center"
			style="position: relative;"
		>
			<div class={dotClass}></div>
			<!-- Add line element that will be toggled -->
			<div class="mobile-dot-line"></div>
		</div>

		<div class="d-flex align-items-start gap-3">
			<div class="d-flex flex-column">
				<h3 class="mobile-step-title h6 fw-bold mb-3">
					{title}
				</h3>

				<div class="d-flex gap-3">
					<div class={numberClass}>{stepNumber}</div>

					<div class="flex-grow-1">
						<div class="mobile-img mb-3">
							<img src={imageSrc} alt={imageAlt} hidden />
						</div>
						<p
							class="small text-muted mb-0"
							style="line-height: 1.5; font-size: 0.875rem;"
						>
							{description}
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	const mobileSteps = document.querySelectorAll(
		".mobile-timeline-step[data-observed]"
	);

	const options = {
		root: null,
		threshold: 0.8,
		rootMargin: "0px",
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			const step = entry.target;
			const dot = step.querySelector(".mobile-dot");
			const stepNumber = step.querySelector(".mobile-step-number");
			const title = step.querySelector(".mobile-step-title");
			const line = step.querySelector(".mobile-dot-line");

			if (entry.isIntersecting) {
				dot?.classList.add("active");
				stepNumber?.classList.add("purple");
				title?.classList.add("active-title");
				// Animate line when step becomes active
				if (line) {
					line.style.height = "var(--line-height)";
				}
			} else {
				dot?.classList.remove("active");
				stepNumber?.classList.remove("purple");
				title?.classList.remove("active-title");
				// Reset line when step leaves view
				if (line) {
					line.style.height = "0";
				}
			}
		});
	}, options);

	mobileSteps.forEach((step) => {
		observer.observe(step);

		// Set CSS custom properties
		step.style.setProperty("--dot-gap", "2rem"); // Gap between dots
		step.style.setProperty("--line-height", "calc(100% - 14px)"); // Line height minus dot size
	});
</script>
