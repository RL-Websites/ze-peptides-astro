---
// MobileTimelineStep.astro
interface Props {
	stepNumber: number;
	title: string;
	description: string;
	imageSrc: string;
	imageAlt: string;
	isActive?: boolean;
	isLast?: boolean;
}

const {
	stepNumber,
	title,
	description,
	imageSrc,
	imageAlt,
	isLast = false,
} = Astro.props;

const dotClass = "mobile-dot";
const numberClass = "mobile-step-number";
---

<div class="mobile-timeline-step" data-observed>
	<div class="d-flex items-start gap-4">
		<div
			class="d-flex flex-column align-items-center"
			style="position: relative;"
		>
			<div class={dotClass}></div>
			<!-- Add line element that will be toggled -->
			<div class="mobile-dot-line"></div>
		</div>

		<div class="d-flex align-items-start gap-3">
			<div class="d-flex flex-column">
				<h3 class="mobile-step-title h6 fw-bold mb-3">
					{title}
				</h3>

				<div class="d-flex gap-3 align-items-start">
					<div class=`${numberClass} mt-10 step-number-mobile`>{stepNumber}</div
					>

					<div class="flex-grow-1">
						<p
							class="small mb-3 mobile-number-description"
							style="line-height: 1.5; font-size: 0.875rem;"
						>
							{description}
						</p>
						<div class="mobile-img">
							<img src={imageSrc} alt={imageAlt} hidden />
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	// This script will run on the client-side
	const mobileSteps = document.querySelectorAll(
		".mobile-timeline-step[data-observed]"
	);

	// Function to remove active class from all steps
	const deactivateAllSteps = () => {
		mobileSteps.forEach((step) => {
			const dot = step.querySelector(".mobile-dot") as HTMLElement | null;
			const stepNumber = step.querySelector(
				".mobile-step-number"
			) as HTMLElement | null;
			const title = step.querySelector(
				".mobile-step-title"
			) as HTMLElement | null;
			const line = step.querySelector(".mobile-dot-line") as HTMLElement | null;
			const description = step.querySelector(
				".mobile-number-description"
			) as HTMLElement | null;

			dot?.classList.remove("active");
			stepNumber?.classList.remove("purple");
			title?.classList.remove("active-title");
			description?.classList.remove("active-title");
			// Reset line when step is not active
			if (line) {
				line.style.height = "0";
			}
		});
	};

	// Function to activate a specific step
	const activateStep = (step: Element) => {
		const dot = step.querySelector(".mobile-dot") as HTMLElement | null;
		const stepNumber = step.querySelector(
			".mobile-step-number"
		) as HTMLElement | null;
		const title = step.querySelector(
			".mobile-step-title"
		) as HTMLElement | null;
		const line = step.querySelector(".mobile-dot-line") as HTMLElement | null;
		const description = step.querySelector(
			".mobile-number-description"
		) as HTMLElement | null;

		dot?.classList.add("active");
		stepNumber?.classList.add("purple");
		title?.classList.add("active-title");
		description?.classList.add("active-title");
		// Animate line when step becomes active
		if (line) {
			line.style.height = "var(--line-height)";
		}
	};

	// Function to find and activate the most centered step
	const updateActiveStep = () => {
		let mostCenteredStep = null;
		let minDistance = Infinity;

		mobileSteps.forEach((step) => {
			const rect = step.getBoundingClientRect();
			const elementCenter = rect.top + rect.height / 2;
			const viewportCenter = window.innerHeight / 2;
			const distance = Math.abs(elementCenter - viewportCenter);

			// Check if element is in viewport
			if (rect.top < window.innerHeight && rect.bottom > 0) {
				if (distance < minDistance) {
					minDistance = distance;
					mostCenteredStep = step;
				}
			}
		});

		// Deactivate all steps first
		deactivateAllSteps();

		// Activate only the most centered step
		if (mostCenteredStep) {
			activateStep(mostCenteredStep);
		}
	};

	// Use scroll event with throttling for better performance
	let ticking = false;
	const handleScroll = () => {
		if (!ticking) {
			window.requestAnimationFrame(() => {
				updateActiveStep();
				ticking = false;
			});
			ticking = true;
		}
	};

	// Set CSS custom properties for all steps
	mobileSteps.forEach((step) => {
		const stepElement = step as HTMLElement;
		stepElement.style.setProperty("--dot-gap", "2rem");
		stepElement.style.setProperty("--line-height", "calc(100% - 14px)");
	});

	// Initial check
	updateActiveStep();

	// Listen to scroll events
	window.addEventListener("scroll", handleScroll);
</script>
