---
// TimelineStep.astro
interface Props {
	stepNumber: number;
	title: string;
	description: string;
	imageSrc: string;
	imageAlt: string;
	isActive?: boolean;
	alignment?: "left" | "right";
}

const {
	stepNumber,
	title,
	description,
	imageSrc,
	imageAlt,
	isActive = false,
	alignment = "left",
} = Astro.props;

// Use simple base classes here, JavaScript will handle the 'active' state on view
const dotClass = "timeline-dot";
const numberClass = "step-number";
---

<div class="timeline-step" data-observed>
	<div class={dotClass}></div>

	{
		alignment === "left" ? (
			<div class="row align-items-center justify-center">
				<div class="col-6 pe-5">
					<div class="timeline-img" style="width: 370px;">
						<img src={imageSrc} alt={imageAlt} />
					</div>
				</div>

				<div class="col-6 ps-5 pt-4">
					<h3 class="step-title h5 fw-bold mb-3">{title}</h3>

					<div class="d-flex align-items-center justify-center gap-4">
						<div class={numberClass}>{stepNumber}</div>
						<p
							class="timeline-description small   mb-0 "
							style="line-height: 1.6;"
						>
							{description}
						</p>
					</div>
				</div>
			</div>
		) : (
			<div class="row align-items-start">
				<div class="col-6 text-start pe-5 pt-4">
					<h3 class="step-title h5 fw-bold mb-3">{title}</h3>

					<div class="d-flex align-items-center justify-center gap-4">
						<div class={numberClass}>{stepNumber}</div>
						<p
							class="timeline-description small  pt-3 mb-0 "
							style="line-height: 1.6;"
						>
							{description}
						</p>
					</div>
				</div>

				<div class="col-6 ps-5 d-flex align-items-start justify-center gap-4">
					<div class="timeline-img" style="width: 370px;">
						<img src={imageSrc} alt={imageAlt} />
					</div>
				</div>
			</div>
		)
	}
</div>

<script>
	// This script will run on the client-side
	const steps = document.querySelectorAll(".timeline-step[data-observed]");

	const options = {
		root: null,
		// The element will be considered "in view" when 50% of it is visible
		threshold: 0.9,
		rootMargin: "0px",
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			const step = entry.target;

			// Cast querySelector results to HTMLElement to resolve TypeScript error
			const dot = step.querySelector(".timeline-dot") as HTMLElement | null;
			const stepNumber = step.querySelector(
				".step-number"
			) as HTMLElement | null;
			const title = step.querySelector(".step-title") as HTMLElement | null;

			if (entry.isIntersecting) {
				// ADD ACTIVE CLASSES
				dot?.classList.add("active");
				stepNumber?.classList.add("purple");
				title?.classList.add("active-title"); // Use a class for CSS color change
			} else {
				// REMOVE ACTIVE CLASSES
				dot?.classList.remove("active");
				stepNumber?.classList.remove("purple");
				title?.classList.remove("active-title");
			}
		});
	}, options);

	steps.forEach((step) => {
		observer.observe(step);
	});
</script>
