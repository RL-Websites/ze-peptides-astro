---
import MobileTimelineStep from "./MobileTimelineStep.astro";
import TimelineStep from "./TimelineStep.astro";

const workImg =
	"Themes/Thrivewellrx.Theme.ZePeptides/assets/img/howitworks/works.png";
---

<section class="how-works py-50 py-md-100">
	<div class="container">
		<div class="text-center mb-md-50 mb-30">
			<h1
				class="site__heading-one mb-3"
				data-aos="fade-up"
				data-aos-duration="600"
			>
				How It &nbsp;<span class="text-primary-grad-1">Works</span>
			</h1>
			<p
				class="text-center mt-20 mt-md-24"
				data-aos="fade-up"
				data-aos-duration="600"
				data-aos-delay="100"
			>
				High-quality research peptides for laboratory use — verified for purity
				and quality
			</p>
		</div>

		<div class="timeline-desktop d-none d-lg-block">
			<TimelineStep
				stepNumber={1}
				title="Consultation & Assessment"
				description="Your transformation begins with a free, no-obligation consultation. We'll learn about your goals, review your health background, and determine whether GLP-1 therapy is right for you. Our team will explain how the medication works, what to expect, and answer all your questions about treatment, cost, and results."
				imageSrc={workImg}
				imageAlt="Doctor consultation"
				alignment="left"
			/>

			<TimelineStep
				stepNumber={2}
				title="Doctor Evaluation & Prescription"
				description="Once you're ready, your health profile is securely submitted to our licensed medical team through Doseward. A state-certified physician reviews your information and schedules a teleconsultation at your convenience. During this call, you can discuss any medical concerns before the doctor finalizes your personalized prescription."
				imageSrc={workImg}
				imageAlt="Doctor evaluation"
				alignment="right"
			/>

			<TimelineStep
				stepNumber={3}
				title="Medication Compounding & Delivery"
				description="After your prescription is approved, our FDA-compliant 503A partner pharmacy compounds your customized medication. Your order is then shipped directly to your home in discreet packaging, along with easy-to-follow administration instructions, nutritional guidance, and lifestyle tips."
				imageSrc={workImg}
				imageAlt="Medication delivery"
				alignment="left"
			/>
		</div>

		<div class="d-lg-none">
			<MobileTimelineStep
				stepNumber={1}
				title="Consultation & Assessment"
				description="Your transformation begins with a free, no-obligation consultation. We'll learn about your goals, review your health background, and determine whether GLP-1 therapy is right for you. Our team will explain how the medication works, what to expect, and answer all your questions about treatment, cost, and results."
				imageSrc={workImg}
				imageAlt="Doctor consultation"
			/>

			<MobileTimelineStep
				stepNumber={2}
				title="Doctor Evaluation & Prescription"
				description="Once you're ready, your health profile is securely submitted to our licensed medical team through Doseward. A state-certified physician reviews your information and schedules a teleconsultation at your convenience. During this call, you can discuss any medical concerns before the doctor finalizes your personalized prescription."
				imageSrc={workImg}
				imageAlt="Doctor evaluation"
			/>

			<MobileTimelineStep
				stepNumber={3}
				title="Medication Compounding & Delivery"
				description="After your prescription is approved, our FDA-compliant 503A partner pharmacy compounds your customized medication. Your order is then shipped directly to your home in discreet packaging, along with easy-to-follow administration instructions, nutritional guidance, and lifestyle tips."
				imageSrc={workImg}
				imageAlt="Medication delivery"
				isLast={true}
			/>
		</div>
	</div>
</section>
