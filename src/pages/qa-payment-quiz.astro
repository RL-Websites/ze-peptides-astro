---
import AssesmentHeader from "../components/AssesmentHeader.astro";
import ClientCard from "../components/ClientCard.astro";
import Footer from "../components/Footer.astro";
import ProductCard from "../components/ProductCard.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<div class="assessment__page-wrapper assessment__page-wrapper__alt">
		<div class="container">
			<div class="assessment">
				<!--Assesment Header Start -->
				<AssesmentHeader />
				<!--Assesment Header End -->
			</div>
		</div>

		<!--===|| Our Products Section Start ||===-->
		<section class="our-products mt-0">
			<div class="container">
				<div class="product__items mt-md-40 mt-30">
					<ProductCard />
				</div>
			</div>
		</section>
		<!--===|| Our Products Section End ||===-->

		<!--Payment method Section Start-->
		<section class="payment__methods section-padding">
			<div class="container">
				<p class="payment__title">
					Payment Methods
					<span class="text-gold-gradient-1">We Accept</span>
				</p>
				<div class="payment__methods__cards">
					<div class="payment__methods__card">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/payment/visa.png"
							alt="Visa"
						/>
					</div>
					<div class="payment__methods__card">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/payment/master.png"
							alt="Master"
						/>
					</div>
					<div class="payment__methods__card">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/payment/amex.png"
							alt="Amex"
						/>
					</div>
					<div class="payment__methods__card">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/payment/jcb.png"
							alt="JCB"
						/>
					</div>
					<div class="payment__methods__card">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/payment/union.png"
							alt="Union"
						/>
					</div>
					<div class="payment__methods__card">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/payment/discover.png"
							alt="Discover"
						/>
					</div>
					<div class="payment__methods__card">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/payment/eft.png"
							alt="EFT"
						/>
					</div>
				</div>
			</div>
		</section>
		<!--Payment method Section end-->

		<!--===|| Client Feedback Section Start ||===-->
		<section class="client">
			<div class="container">
				<div class="section__title d-md-flex align-items-center gap-3">
					<h2
						class="site__heading-two text-secondary client__title text-md-start text-center"
						>What People Say About Us</h2
					>
					<div class="d-md-block d-none">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/frame-with-title-green.svg"
							alt="frame "
						/>
					</div>
				</div>
			</div>
			<div class="container-fluid mx-0 px-0 client__slider">
				<div class="row mt-md-50">
					<div class="col-md-3 client__arrow">
						<div class="client__navigation">
							<div class="prev-arrow"> <i class="icon-left-arrow"></i></div>
							<div class="next-arrow"> <i class="icon-right-arrow"></i></div>
						</div>
					</div>
					<div class="col-md-9">
						<ClientCard />
					</div>
				</div>
			</div>
		</section>
		<!--===|| Client Feedback Section End ||===-->

		<!--Footer Section end-->
		<Footer />
	</div>
</Layout>
