---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<Header />

	<!-- =====|| Main Section Start ||====== -->

	<main class="page">
		<!-- ==|| Login Section Start ||== -->
		<section class="login">
			<div class="login-container rounded-4">
				<div class="top-container text-center">
					<h1 class="title mb-1 text-primary-grad-1">Returning Customer</h1>
					<p class="subtitle text-primary-grad-1"
						>Log in to confirm your journey</p
					>
				</div>

				<form class="needs-validation" novalidate>
					<div class="form-div w-full">
						<label for="email" class="form-label">
							Email Address <span class="text-danger">*</span>
						</label>
						<input
							type="email"
							class="form-control form-control-lg"
							id="email"
							value="John_07@gmail.com"
							required
						/>
						<div class="invalid-feedback">Please enter a valid email.</div>
					</div>

					<div class="form-div w-full">
						<label for="password" class="form-label">
							Password <span class="text-danger">*</span>
						</label>
						<input
							type="password"
							class="form-control form-control-lg"
							id="password"
							value="@Ykhfy65475$ghj"
							required
						/>
						<div class="invalid-feedback">Password must not be empty.</div>
					</div>

					<div
						class="form-div d-flex align-items-center justify-content-start mb-4"
					>
						<div class="form-check">
							<input
								class="form-check-input"
								type="checkbox"
								id="remember"
								checked
							/>
							<label class="form-check-label" for="remember">
								Remember me
							</label>
						</div>
					</div>
					<div class="btn-div">
						<button
							type="submit"
							class="theme-btn theme-btn__primary theme-btn__min-w-100 w-100 btn-lg mb-4"
						>
							Log In
						</button>

						<div class="text-center mt-3">
							<a
								href="#"
								class="d-block mb-3 text-link text-decoration-underline forgot-text"
								>Forgot Password?</a
							>
							<p class="first-time-text">
								First-time Visitor? <a
									href="#"
									class="text-link text-decoration-underline fw-medium"
									>Create an account</a
								>
							</p>
						</div></div
					>
				</form>
			</div>
		</section>
	</main>
	<!-- ==|| Login Section End ||== -->
</Layout>

<Footer />
