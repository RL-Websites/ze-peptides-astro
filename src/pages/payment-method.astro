---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Toast from "../components/Toast.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<Header />

	<!-- =====|| Main Section Start ||====== -->
	<main class="page">
		<div class="page__wrapper page__wrapper--alt">
			<!-- ==|| Cart Hero Section Start ||== -->
			<section class="cart-hero">
				<div class="container">
					<h1 class="text-primary-grad-1 text-center"
						>Payment Method</h1
					>
				</div>
			</section>
			<!-- ==|| Cart Hero Section End ||== -->

			<!-- ==|| Payment List Section Start ||== -->
			<section class="payment__card">
				<div class="container">
					<div class="row">
						<div class="col-12 col-lg-8">
							<div
								class="payment-card__body cart-card payment__card--cart-summary"
							>
								<div class="cart-card__header">
									<h3>Payment Details</h3>
								</div>
								<div
									class="payment__form payment__form--body payment__form--card"
									id="payment-form"
								>
									<div class="form-group">
										<label class="fw-bold mb-5" for="cardNumber"
											>Card Number</label
										>
										<div class="payment__form--card-variation">
											<input
												inputmode="numeric"
												class="basic-input card-input"
												type="text"
												id="cardNumber"
												placeholder="1234 1234 1234 1234"
											/>
											<div class="card-icons">
												<img
													src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/visa.png"
													alt="Visa"
												/>
												<img
													src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/master.png"
													alt="Mastercard"
												/>
												<img
													src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/amex.png"
													alt="AMEX"
												/>
												<img
													src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/jcb.png"
													alt="JCB"
												/>
											</div>
										</div>
									</div>

									<div class="payment__form--inline-fields mt-20">
										<div class="form-group">
											<label class="fw-bold mb-5" for="expiry"
												>Expiration Date</label
											>
											<input
												inputmode="numeric"
												class="basic-input"
												type="text"
												id="expiry"
												placeholder="MM/YY"
											/>
										</div>
										<div class="form-group">
											<label class="fw-bold mb-5" for="cvc">Security Code</label
											>
											<input
												inputmode="numeric"
												class="basic-input"
												type="text"
												id="cvc"
												placeholder="CVC"
											/>
										</div>
									</div>

									<div class="select__items mb-0">
										<label class="fw-bold mb-5" for="country">Country</label>
										<select
											class="select__options text-secondary fw-normal"
											name="country"
											id="country"
										>
											<option value="">Select a country</option>
											<option value="Afghanistan">Bangladesh</option>
											<option value="Albania">India</option>
											<option value="Algeria">Pakistan</option>
											<option value="Andorra">USA</option>
											<option value="Angola">Canada</option>
										</select>
									</div>
								</div>
							</div>
						</div>
						<div class="col-12 col-lg-4 payment__card--right">
							<div class="cart-card">
								<div class="cart-card__header">
									<h3 class="fs-md-24 fs-20 fw-bold">Cart Total <span class="fs-16 fw-normal">(4 items)</span></h3>
								</div>
								<div class="cart-card__body">
									<div class="pricing__basic">
										<div class="pricing__item">
											<p class="pricing__item--name">Subtotal</p>
											<p class="pricing__item--value">$150.50</p>
										</div>
										<div class="pricing__item">
											<p class="pricing__item--name">Shipping</p>
											<p class="pricing__item--value">$30.50</p>
										</div>
										<div class="pricing__item">
											<p class="pricing__item--name">Consultancy Fee</p>
											<p class="pricing__item--value">$30.50</p>
										</div>
									</div>

									<div class="coupon pricing__coupon">
										<p class="coupon__label">Coupon Code</p>
										<div class="dnn-tag">
											<i class="icon-promo-code dnn-tag__icon"></i>
											<span class="dnn-tag__text" data-bind="text: billDiscountCode()"></span>
										</div>
									</div>

									<div class="pricing__total">
										<div class="pricing__item">
											<p class="pricing__item--name">Discount</p>
											<p class="pricing__item--value text-dark-red-2">
												-$5.50
											</p>
										</div>

										<div class="pricing__total-item">
											<p class="pricing__total--name">Total</p>
											<p class="pricing__total--value">$175.87</p>
										</div>
									</div>
								</div>
							</div>
							

							<!-- <div class="attention mt-20">
								<div class="attention__box">
									<p class="attention__title">
													<i class="icon-alert"></i>
													<span>Attention: This is not the final charge</span>
												</p>

									<div class="attention__title">
										<i class="icon-alert text-secondary"></i>
										<p
											>Attention:
											<span>Final Dosage Determined by Doctor</span></p
										>
									</div>

									<p class="attention__price-desc">
													<span>$150.50</span> + <span>Shipping</span> +
													<span>Consultation fee</span>
												</p>

									<p class="attention__text">
										The highest dosage price is only a credit card hold until
										the doctor consultation. The final price will be adjusted
										based on the prescribed dosage.
									</p>
								</div>
							</div> -->
						</div>
					</div>
					<!-- ALert section start -->
					<div class="attention pb-40 mt-40">
												<div class="attention__box">

													<div class="attention__title">
														<!-- <i class="icon-alert"></i> -->
														<p>GLP-1, Peptides, TRT/HRT, and Other Prescription Treatments</p>
													</div>

													<p class="attention__text">
														Your card will not be charged at checkout. 
														We securely store your payment information 
														and only process the charge once a doctor 
														reviews your intake form and issues your 
														prescription. If you are not approved, you 
														will not be charged.
													</p>
													<div class="attention__title">
														<!-- <i class="icon-alert"></i> -->
														<p>DotFit, Skin Care & Pain Relief Products (Non-Prescription)</p>
													</div>

													<p class="attention__text">
														These items do not require a doctor review or intake form. 
														Your card will be charged immediately at checkout, and your 
														order will proceed directly to fulfillment.
													</p>
												</div>
											</div>
					<!-- ALert section end -->
				</div>
			</section>
			<!-- ==|| Payment List Section End ||== -->

			

			<!-- ==|| Shipping info Section Start ||== -->
			<section class="mt-40">
				<div class="container">
					<div class="payment__card mt-0">
						<div class="payment__header">
							<h3 class="fs-md-24 fs-18 fw-bold">Shipping Info</h3>

							<div>
								<label class="custom-check d-flex align-items-center">
									<span class="custom-check__input custom-check__input--alt">
										<input type="checkbox" />
										<span class="black-icon"></span>
									</span>
									<span class="custom-check__label">
										Save this Information
									</span>
								</label>
							</div>
						</div>
						<div class="payment__body">
							<div class="payment__form">
								<form>
									<div class="payment__wrapper">
										<div class="payment__input">
											<label class="basic-label" for="shippingName"
												>Name <span class="icon-ellipse"></span></label
											>
											<input
												class="basic-input"
												type="text"
												name="shippingName"
												id="shippingName"
												placeholder=""
											/>
											<p class="basic-error">Shipping name is required</p>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingAddress"
												>Address <span class="icon-ellipse"></span></label
											>
											<input
												class="basic-input"
												type="email"
												name="shippingAddress"
												id="shippingAddress"
											/>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingAddress"
												>State <span class="icon-ellipse"></span></label
											>

											<div class="select__wrapper select__wrapper--alt">
												<select
													class="select__options select__options--padding fs-16 text-secondary"
												>
													<option value="1">1</option>
													<option value="2">2</option>
													<option value="3">3</option>
													<option value="4">4</option>
												</select>
											</div>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingAddress"
												>City <span class="icon-ellipse"></span></label
											>
											<input
												class="basic-input"
												type="email"
												name="shippingAddress"
												id="shippingAddress"
											/>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingZipCode"
												>Zip Code <span class="icon-ellipse"></span></label
											>
											<input
												inputmode="numeric"
												class="basic-input"
												type="text"
												name="shippingZipCode"
												id="shippingZipCode"
											/>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingEmail"
												>Email Address <span class="icon-ellipse"></span></label
											>
											<input
												class="basic-input"
												type="email"
												name="shippingEmail"
												id="shippingEmail"
											/>
										</div>
									</div>
								</form>
							</div>
						</div>
					</div>
				</div>
			</section>
			<!-- ==|| Shipping info Section End ||== -->

			<!-- ==|| Billing Section Start ||== -->
			<section class="payment__billing mt-50 mt-md-100">
				<div class="container">
					<div class="payment__card mt-0">
						<div class="payment__header">
							<h3 class="fs-md-24 fs-20 fw-bold">Billing Info</h3>

							<div>
								<label class="custom-check">
									<span class="custom-check__input custom-check__input--alt">
										<input type="checkbox" />
										<span class="black-icon"></span>
									</span>
									<span class="custom-check__label">
										Same as shipping Information
									</span>
								</label>
								<label class="custom-check ml-20">
									<span class="custom-check__input custom-check__input--alt">
										<input type="checkbox" />
										<span class="black-icon"></span>
									</span>
									<span class="custom-check__label">
										Save this Information
									</span>
								</label>
							</div>
						</div>
						<div class="payment__body">
							<div class="payment__form">
								<form>
									<div class="payment__wrapper">
										<div class="payment__input">
											<label class="basic-label" for="shippingName"
												>Name <span class="icon-ellipse"></span></label
											>
											<input
												class="basic-input"
												type="text"
												name="shippingName"
												id="shippingName"
											/>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingAddress"
												>Address <span class="icon-ellipse"></span></label
											>
											<input
												class="basic-input"
												type="email"
												name="shippingAddress"
												id="shippingAddress"
											/>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingAddress"
												>State <span class="icon-ellipse"></span></label
											>
											<div class="select__wrapper select__wrapper--alt">
												<select
													class="select__options select__options--padding fs-16 text-secondary"
												>
													<option value="1">1</option>
													<option value="2">2</option>
													<option value="3">3</option>
													<option value="4">4</option>
												</select>
											</div>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingAddress"
												>City <span class="icon-ellipse"></span></label
											>
											<input
												class="basic-input"
												type="email"
												name="shippingAddress"
												id="shippingAddress"
											/>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingZipCode"
												>Zip Code <span class="icon-ellipse"></span></label
											>
											<input
												inputmode="numeric"
												class="basic-input"
												type="text"
												name="shippingZipCode"
												id="shippingZipCode"
											/>
										</div>
										<div class="payment__input">
											<label class="basic-label" for="shippingEmail"
												>Email Address <span class="icon-ellipse"></span></label
											>
											<input
												class="basic-input"
												type="email"
												name="shippingEmail"
												id="shippingEmail"
											/>
										</div>
									</div>
								</form>
							</div>
						</div>
					</div>

					<div class="condition__highlight mt-50">
						<p class="mb-0"
							>This product is not dispensed without intake review and provider
							clearance.</p
						>
					</div>
					<div class="mt-30">
						<label class="custom-check mt-15">
							<span class="custom-check__input">
								<input type="checkbox" data-bind="checked: hasAnsweredTruthfully" />
								<span></span>
							</span>

							<span class="custom-check__label">
								I confirm that all information associated with my treatment is accurate and that I
								understand these medications must be used only under the supervision of a licensed
								healthcare provider.
							</span>
						</label>
						<p class="basic-error"
							data-bind="visible: isSubmitted, validationMessage: hasAnsweredTruthfully"></p>
					</div>

					<div>
						<label class="custom-check mt-15">
							<span class="custom-check__input">
								<!--<input type="checkbox" data-bind="checked: agreedToTermsAndConditions" />-->
								<input type="checkbox"
									data-bs-toggle="modal"
                   data-bs-target="#termCodition" />
								<span></span>
							</span>

							<span class="custom-check__label">
								Please read the terms & conditions—purchase cannot be completed without your acknowledgment.

							</span>
						</label>
						<p class="basic-error" data-bind="visible: isSubmitted, validationMessage: agreedToTermsAndConditions"></p>

					</div>


					<div class="step-btn text-end mt-40">
						<button
							type="button"
							class="theme-btn theme-btn__outline theme-btn__outline--primary cursor-pointer theme-btn__min-w-210"
						>
							Go Back
						</button>
						<button
							type="button"
							class="theme-btn theme-btn__primary theme-btn__min-w-210 theme-btn__primary--signin theme-btn--with-loader"
							data-bs-toggle="modal"
							data-bs-target="#payment"
						>
							Next

							<span class="theme-btn__loader spin"></span>
						</button>
					</div>
				</div>
			</section>
			<!-- ==|| Billing Section End ||== -->
		</div>
	</main>
	<!-- =====|| Main Section End ||====== -->

	<!-- =====|| Payment Successful Modal Start ||====== -->
	<div
		id="payment"
		class="modal fade payment-modal confirm-modal"
		tabindex="-1"
		aria-labelledby="payment"
		aria-hidden="true"
	>
		<div class="modal-dialog" role="document">
			<div class="modal-content">
				<!-- <button type="button" class="btn-close" data-dismiss="modal">
					<i class="icon-cross_filled"></i>
				</button> -->

				<div class="modal-body">
					<div class="modal__icon">
						<i class="icon-tick-outlined"></i>
					</div>
					<div class="modal__text">
						<h5 class="site__heading-five fw-bold text-secondary text-center"
							>Payment Successful
						</h5>
					</div>

					<p
						class="text-blue-6 text-center mb-20 fs-md-18 fs-16 mt-md-30 mt-10"
					>
						Thank you for your payment. Your order is now being processed. If
						necessary, a prescriber will contact you to discuss the next steps
						in your treatment.
					</p>
					<p class="modal__highlight-text">
						This product requires a lab test for proper evaluation. We will send
						you a lab test kit, or you can choose to visit our nearest lab for
						testing. Once the test results are available, we will proceed with
						the next steps in your treatment.
					</p>

					<div class="modal__actions">
						<button
							class="modal__action modal__action--outline"
							type="button"
							data-bs-dismiss="modal"
							aria-label="Close"
						>
							I Will Do It Later
						</button>
						<button class="modal__action modal__action--primary" type="button">
							Upload Documents
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- =====|| Payment Successful Modal End ||====== -->

	<!-- =====|| Toast Start ||====== -->
	<Toast />
	<!-- =====|| Toast Start ||====== -->

	<!-- Terms & Condition Modal Start -->
	<div
		id="termCodition"
		class="modal fade terms-condition-modal"
		tabindex="-1"
		role="dialog"
	>
		<div class="modal-dialog" role="document">
			<div class="modal-content">
				<!-- <button type="button" class="btn-close-filled" data-dismiss="modal">
					<i class="icon-cross_filled"></i>
				</button> -->

				<div class="modal-header">
					<h2 class="section__title"> Terms and Conditions </h2>
				</div>

				<div class="modal-body">
