	</div>
</div>
<!-- Lab Report Modal End-->

<!-- Intake Form Modal Start-->
<div
	class="modal fade intake-form-modal"
	id="modal-intake-form-view"
	tabindex="-1"
	role="dialog"
>
	<div class="modal-dialog" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<p class="modal-title fs-36 fw-600">Intake Form</p>

				<button
					type="button"
					class="modal-close btn-close"
					data-dismiss="modal"
					aria-label="Close"
				>
					<i class="icon-cross_filled"></i>
				</button>
			</div>
			<div class="modal-body modal-body__alt">
				<div class="modal__qa">
					<p class="modal__ques">1. Are you diabetic?</p>
					<p class="modal__ans">-Yes</p>
				</div>
				<div class="modal__qa">
					<p class="modal__ques"
						>2. Please list any oral medications or insulins you take (for
						diabetics). If none, please answer 'none'.</p
					>
					<p class="modal__ans"
						>- Metformin, Glipizide, Insulin Aspart (NovoLog), Insulin Lispro
						(Humalog), Insulin Glargine (Lantus).</p
					>
				</div>
				<div class="modal__qa">
					<p class="modal__ques"
						>3. Do you have high blood pressure or heart problems?</p
					>
					<p class="modal__ans">- Yes</p>
				</div>
				<div class="modal__qa">
					<p class="modal__ques"
						>4. List of oral medicines (for high blood pressure). Or answer
						none.</p
					>
					<p class="modal__ans"
						>- Metformin, Glipizide, Insulin Aspart (NovoLog), Insulin Lispro
						(Humalog), Insulin Glargine (Lantus).</p
					>
				</div>
				<div class="modal__qa">
					<p class="modal__ques"
						>5. List of other oral medicines (for these conditions) . Or answer
						none.</p
					>
					<p class="modal__ans"
						>- Metformin, Glipizide, Insulin Aspart (NovoLog), Insulin Lispro
						(Humalog), Insulin Glargine (Lantus).</p
					>
				</div>
				<div class="modal__qa">
					<p class="modal__ques"
						>6. List of any other oral medicines (for other conditions) . Or
						answer none.</p
					>
					<p class="modal__ans"
						>- Metformin, Glipizide, Insulin Aspart (NovoLog), Insulin Lispro
						(Humalog), Insulin Glargine (Lantus).</p
					>
				</div>
				<div class="modal__qa">
					<p class="modal__ques">7. Are you allergic to any medication?</p>
					<p class="modal__ans">- Yes</p>
				</div>
				<div class="modal__qa">
					<p class="modal__ques"
						>8. List any medicines you’re allergic to. Or answer none.</p
					>
					<p class="modal__ans"
						>- Metformin, Glipizide, Insulin Aspart (NovoLog), Insulin Lispro
						(Humalog), Insulin Glargine (Lantus).</p
					>
				</div>
				<div class="modal__qa">
					<p class="modal__ques"
						>9. Have you seen a doctor in the last 12 months?</p
					>
					<p class="modal__ans">- Yes</p>
				</div>
				<div class="modal__qa">
					<p class="modal__ques">10. Are you pregnant or breast feeding?</p>
					<p class="modal__ans">- Yes</p>
				</div>
				<div class="modal__qa">
					<p class="modal__ques">11. Do you experience a lack of energy?</p>
					<p class="modal__ans">- Yes</p>
				</div>
			</div>
		</div>
	</div>
</div>
<!--Intake Form Modal End-->
