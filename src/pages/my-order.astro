									<td>
										<button type="button" class="view-button">View</button>
									</td>
								</tr>
								<tr>
									<td>Ammonia</td>
									<td class="text-uppercase">pdf</td>
									<td>
										<button type="button" class="view-button">View</button>
									</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			</div>
