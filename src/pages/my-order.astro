<!-- Lab Report Modal Start-->
<div
	class="modal fade lab-report-modal"
	id="view-reports-modal"
	tabindex="-1"
	role="dialog"
	aria-labelledby="myModalLabel"
>
	<div class="modal-dialog" role="document">
		<div class="modal-content overflow-h">
			<div class="modal-header">
				<p class="modal-title fs-22">Lab Reports</p>

				<button
					type="button"
					class="modal-close btn-close"
					data-dismiss="modal"
					aria-label="Close"
				>
					<i class="icon-cross_filled"></i>
				</button>
			</div>
			<div class="modal-body p-0">
				<div class="list-table">
					<div class="table-responsive">
						<table class="table table-striped table__alt">
							<thead>
								<tr>
									<th>Report Name</th>
									<th>File Type</th>
									<th>Details</th>
								</tr>
							</thead>

							<tbody>
								<tr>
									<td>CVC Report</td>
									<td class="text-uppercase">PDF</td>
									<td>
										<button type="button" class="view-button">View</button>
									</td>
								</tr>

								<tr>
									<td>Biilirubin</td>
									<td class="text-uppercase">jpg</td>
									<td>
										<button type="button" class="view-button">View</button>
									</td>
								</tr>

								<tr>
									<td>Ammonia</td>
									<td class="text-uppercase">png</td>
									<td>
										<button type="button" class="view-button">View</button>
									</td>
								</tr>
								<tr>
									<td>Amylase</td>
