																<th>Direction</th>
																<th>Status</th>
															</tr>
														</thead>
														<tbody>
															<tr>
																<td>Epic Chew</td>
																<td>5</td>
																<td
																	>1 tablet (5 mg) by mouth once daily as
																	needed, 30–60 minutes before activity</td
																>
																<td
																	><span
