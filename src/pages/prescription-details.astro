---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<Header />

	<main class="page">
		<div class="page__wrapper page__wrapper--alt">
			<section class="order-details">
				<button
					type="button"
					class="btn btn-primary"
					data-bs-toggle="modal"
					data-bs-target="#prescriptionModal"
				>
					Open Modal
				</button></section
			>
		</div>
	</main>

	<!--Modal UI Start -->
	<div
		class="modal p-0 fade prescription-modal"
		id="prescriptionModal"
		tabindex="-1"
		aria-labelledby="prescriptionModalLabel"
		aria-hidden="true"
	>
		<div class="modal-dialog modal-fullscreen">
			<div class="modal-content">
				<div class="perscription-modal__modal-header">
					<div class="modal-header-title me-auto">
						<p>Prescription</p>
					</div>
					<div class="btn-modal-close">
						<button
							type="button"
							class="btn btn-outline border-0"
							data-bs-dismiss="modal"
							aria-label="Close"
						>
							<i class="icon-cross_filled btn-close-icon"></i>
						</button>
					</div>
				</div>

				<div class="modal-body p-3">
					<!-- Prescriber Details -->
					<div class="d-flex flex-column gap-3">
						<div class="card-basic card-basic--no-shadow">
							<div class="card-basic__header">
								<p class="card-basic__title">Prescriber Details:</p>
							</div>
							<div class="card-basic__body card-basic--no-shadow">
								<div class="medicine-info">
									<div class="medicine-info__item">
										<p class="medicine-info__label">Name:</p>
										<p class="medicine-info__text">Mike Scott</p>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">DEA:</p>
										<p class="medicine-info__text">N/A</p>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">NPI:</p>
										<p class="medicine-info__text">N/A</p>
									</div>
								</div>
							</div>
						</div>

						<!-- Patient Details -->
						<div class="card-basic card-basic--no-shadow">
							<div class="card-basic__header">
								<p class="card-basic__title">Patient Details:</p>
							</div>
							<div class="card-basic__body">
								<div class="medicine-info">
									<div class="medicine-info__item">
										<p class="medicine-info__label">Name:</p>
										<p class="medicine-info__text">Dorian Higgins</p>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">Gender:</p>
										<p class="medicine-info__text">Male</p>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">Cell Phone:</p>
										<p class="medicine-info__text">(929) 782-9239</p>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">Email:</p>
										<p class="medicine-info__text"
											>rl_dorian.higgins@yopmail.com</p
										>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">Address:</p>
										<p class="medicine-info__text"
											>23 Farm to Market 2296, 8, Huntsville, Texas, 77340</p
										>
									</div>
								</div>
							</div>
						</div>

						<!-- Prescription Details -->
						<div class="card-basic card-basic--no-shadow">
							<div class="card-basic__header">
								<p class="card-basic__title">Prescription Details:</p>
							</div>
							<div class="card-basic__body">
								<div class="medicine-info">
									<div class="medicine-info__item">
										<p class="medicine-info__label">Package Name:</p>
										<p class="medicine-info__text">MI Package</p>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">Preferred Pharmacy:</p>
										<p class="medicine-info__text">Male</p>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">Sent Pharmacy:</p>
										<p class="medicine-info__text">(929) 782-9239</p>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">RX Number:</p>
										<p class="medicine-info__text"
											>rl_dorian.higgins@yopmail.com</p
										>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">Allergy Info:</p>
										<p class="medicine-info__text"
											>23 Farm to Market 2296, 8, Huntsville, Texas, 77340</p
										>
									</div>
									<div class="medicine-info__item">
										<p class="medicine-info__label">Created Date:</p>
										<p class="medicine-info__text">03 March, 2026 10:03 AM</p>
									</div>
								</div>
							</div>
						</div>

						<!-- Document Information -->
						<div class="card-basic card-basic--no-shadow">
							<div class="card-basic__header">
								<p class="card-basic__title">Document Information:</p>
							</div>
							<div class="card-basic__body">
								<div class="document-info d-flex flex-row gap-4">
									<div
										class="document-info__item d-flex flex-column align-items-start"
									>
										<p class="document-info__label">Intake Form:</p>
										<button type="button" class="view-button">View</button>
									</div>
									<div
										class="document-info__item d-flex flex-column align-items-start"
									>
										<p class="document-info__label">Driving License:</p>
										<button type="button" class="view-button">View</button>
									</div>
								</div>
							</div>
						</div>

						<!-- TRT Cycles -->
						<div class="mt-3">
							<p class="card-basic__title mb-3">TRT Cycles</p>

							<div class="card-basic__body">
								<!-- Cycle 1 -->
								<div class="card-basic mb-3 bg-white">
									<div
										class="card-basic__header d-flex flex-column align-items-start gap-1 border-0"
									>
										<div class="d-flex align-items-center gap-2">
											<p class="card-basic__title mb-0">Cycle#1</p>
											<span
												class="status-pill status-pill--active fs-16 fw-700 text-black"
