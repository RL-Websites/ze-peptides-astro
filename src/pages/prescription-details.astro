											>
											<div class="d-flex align-items-center gap-2">
												<span class="fw-700 fs-16">Lab Reports:</span>
												<a href="#" class="text-primary">Upload Report</a>
												<i class="icon-upload text-primary fw-700"></i>
												<span class="text-gray">|</span>
												<i class="icon-download-04 text-primary fw-700"></i>
											</div>
										</div>
									</div>
									<div class="card-basic__body p-0">
										<!-- Desktop table -->
										<div class="d-md-block d-none">
											<div class="list-table">
												<div class="table-responsive">
													<table class="table order-list mb-0">
														<thead>
															<tr>
																<th>Medication</th>
																<th>Strength</th>
																<th>Direction</th>
																<th>Status</th>
															</tr>
														</thead>
														<tbody>
															<tr>
																<td>Epic Chew</td>
																<td>5</td>
																<td
																	>1 tablet (5 mg) by mouth once daily as
																	needed, 30–60 minutes before activity</td
																>
																<td
																	><span
																		class="status-pill status-pill--pending fs-12"
																		>Waiting for Doctor</span
																	></td
																>
															</tr>
															<tr>
																<td>3 Month Tirzepatide</td>
																<td>15</td>
																<td>Inject 0.5 mL subcutaneously once weekly</td
																>
																<td
																	><span
																		class="status-pill status-pill--pending fs-12"
																		>Waiting for Doctor</span
																	></td
																>
															</tr>
														</tbody>
													</table>
												</div>
											</div>
										</div>
										<!-- Mobile stacked -->
										<div class="d-md-none d-block px-3 py-3">
											<div class="custom-table">
												<div class="custom-table__item">
													<div class="custom-table__header"
														><p class="custom-table__header__text">Medication</p
														></div
													>
													<div class="custom-table__data">Epic Chew</div>
												</div>
												<div class="custom-table__item">
													<div class="custom-table__header"
														><p class="custom-table__header__text">Strength</p
														></div
													>
													<div class="custom-table__data">5</div>
												</div>
												<div class="custom-table__item">
													<div class="custom-table__header"
