													<div class="custom-table__header"
														><p class="custom-table__header__text">Medication</p
														></div
													>
													<div class="custom-table__data"
														>3 Month Tirzepatide</div
													>
												</div>
												<div class="custom-table__item">
													<div class="custom-table__header"
														><p class="custom-table__header__text">Strength</p
														></div
													>
													<div class="custom-table__data">15</div>
												</div>
												<div class="custom-table__item">
													<div class="custom-table__header"
														><p class="custom-table__header__text">Direction</p
														></div
													>
													<div class="custom-table__data"
														>Inject 0.5 mL subcutaneously once weekly</div
													>
												</div>
												<div class="custom-table__item">
													<div class="custom-table__header"
														><p class="custom-table__header__text">Status</p
														></div
													>
													<div class="custom-table__data"
														><span
															class="status-pill status-pill--pending fs-12"
															>Waiting for Doctor</span
														></div
													>
												</div>
											</div>
										</div>
									</div>
								</div>

								<!-- Cycle 2 -->
								<div class="card-basic mb-3 bg-white">
									<div
										class="card-basic__header d-flex flex-column align-items-start gap-1 border-0"
