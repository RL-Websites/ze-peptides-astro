---
import Client from "../components/Client.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HowItWorks from "../components/homePage/HowItWorks.astro";
import WhyChooseUs from "../components/homePage/WhyChooseUs.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<Header />
	<!-- =====|| Main Section Start ||====== -->
	<main class="page">
		<!-- ==|| Product Hero Section Start ||== -->
		<section class="product-hero bg-white">
			<div class="container">
				<div class="row align-items-start">
					<div class="col-xl-5 col-md-6 product-hero__left-col">
						<div class="product-hero__left">
							<img
								src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/products/product-2.png"
								class="product-hero__img"
								alt="Product"
							/>
						</div>
					</div>
					<div class="col-xl-7 col-md-6">
						<div class="product-hero__right">
							<div class="d-flex align-items-start">
								<h2>Focus and Mood Blend - PE-22-28/Pinealon/Selank</h2>
								<span class="badge rounded-pill bg-pink-2 text-red ml-auto mt-1">
									Out of Stock
								</span>
							</div>
							<h3 class="mt-12 text-primary-grad-1">$450</h3>
							<h5 class="mt-12 text-gray-dark">Purity: 99.9%</h5>
							<div class="alert-pill mt-20 mt-md-24">
								<i class="icon-alert"></i>
								<span
									>For Research Purposes Only — Not for Human Consumption</span
								>
							</div>

							<div class="product-hero__cart mt-24">
								<div class="product-action">
									<div
										class="input-group product-action__cart product-action__cart--lg"
									>
										<span class="input-group-btn">
											<button class="btn" type="button">
												<i class="icon-minus"></i>
											</button>
										</span>
										<input
											type="text"
											class="form-control"
											id="quantity"
											value="1"
										/>
										<span class="input-group-btn">
											<button class="btn" type="button">
												<i class="icon-plus1"></i>
											</button>
										</span>
									</div>

									<div class="product-action__btn mt-24">
										<!-- <button
											type="button"
											class="theme-btn theme-btn__primary theme-btn__primary--uppercase"
											>
											Out Of Stock
											</button> -->
										<button
											type="button"
											class="theme-btn theme-btn__outline theme-btn__outline--primary"
										>
											Buy Now
										</button>
										<button type="button" class="theme-btn theme-btn__primary">
											Add to Cart
										</button>
									</div>
								</div>
							</div>

							<ul
								class="nav nav-pills nav-pills__custom mb-3"
								id="pills-tab"
								role="tablist"
							>
								<li class="nav-item" role="presentation">
									<button
										class="nav-link active"
										id="pills-home-tab"
										data-bs-toggle="pill"
										data-bs-target="#pills-home"
										type="button"
										role="tab"
										aria-controls="pills-home"
										aria-selected="true"
									>
										1 Month Program
									</button>
								</li>
								<li class="nav-item" role="presentation">
									<button
										class="nav-link"
										id="pills-profile-tab"
										data-bs-toggle="pill"
										data-bs-target="#pills-profile"
										type="button"
										role="tab"
										aria-controls="pills-profile"
										aria-selected="false">3 Month Program</button
									>
								</li>
							</ul>
							<div
								class="tab-content tab-content__custom"
								id="pills-tabContent"
							>
								<div
									class="tab-pane fade show active"
									id="pills-home"
									role="tabpanel"
									aria-labelledby="pills-home-tab"
								>
									<div class="tab-pills">
										<div class="tab-pills__single">
											<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
												>.50mg</span
											>
											<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
										</div>
										<div class="tab-pills__single">
											<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
												>500mg</span
											>
											<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$1099</span>
										</div>
										<div class="tab-pills__single">
											<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
												>.50mg</span
											>
											<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
										</div>
										<div class="tab-pills__single">
											<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
												>.50mg</span
											>
											<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
										</div>
										<div class="tab-pills__single">
											<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
												>.50mg</span
											>
											<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
										</div>
										<div class="tab-pills__single">
											<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
												>.50mg</span
											>
											<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
										</div>
									</div>
								</div>
								<div
									class="tab-pane fade"
									id="pills-profile"
									role="tabpanel"
									aria-labelledby="pills-profile-tab">..3.</div
								>
							</div>

							<div
								class="text-body3 text-gray-dark mt-20 mt-md-24 product-hero__details"
							>
								Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
								eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut
								enim ad minim veniam, quis nostrud exercitation ullamco laboris
								nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor
								in reprehenderit in voluptate velit esse cillum dolore eu fugiat
								nulla pariatur. Excepteur sint occaecat cupidatat non proident,
								sunt in culpa qui officia deserunt mollit anim id est laborum.
								Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
								eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut
								enim ad minim veniam, quis nostrud exercitation ullamco laboris
								nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor
								in reprehenderit in voluptate velit esse cillum dolore eu fugiat
								nulla pariatur. Excepteur sint occaecat cupidatat non proident,
								sunt in culpa qui officia deserunt mollit anim id est laborum.
								Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
								eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut
								enim ad minim veniam, quis nostrud exercitation ullamco laboris
								nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor
								in reprehenderit in voluptate velit esse cillum dolore eu fugiat
								nulla pariatur. Excepteur sint occaecat cupidatat non proident,
								sunt in culpa qui officia deserunt mollit anim id est laborum.

								<div class="read-more">
									<span id="readMore" class="text-body3"> Read More </span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
		<!-- ==|| Product Section End ||== -->
	
		<!--===|| How it Works Section Start ||===-->
	
		<HowItWorks />
	
		<!--===|| How it Works Section End ||===-->
	
		<!-- Why Choose Us ZePeptides Section Start -->
		<WhyChooseUs />
		<!-- Why Choose Us ZePeptides Section End -->
	
		<!--===|| Faq Section Start ||===-->
		<section class="faq py-50 py-md-100">
			<div class="container faq__wrapper">
				<div class="row">
					<div class="col-lg-12 faq__items">
						<Faq />
					</div>
				</div>
			</div>
		</section>
		<!--===|| Faq Section End ||===-->
	
		<!--===|| Client Feedback Section Start ||===-->
		<Client />
		<!--===|| Client Feedback Section End ||===-->
	
		<!--=====|| Main Section End ||=====-->
	</main>
</Layout>

<!-- =====|| Main Section End ||====== -->
<Footer />

<!-- Dose Modal Start -->
<div id="doses" class="modal fade dose-modal" tabindex="-1" role="dialog">
	<div class="modal-dialog" role="document">
		<div class="modal-content">
			<!-- <button type="button" class="btn-close" data-dismiss="modal">
				<i class="icon-cross_filled"></i>
			</button> -->

			<div class="modal-body">
				<div class="modal__text mt-0">
					<p>Select Program</p>
				</div>
				<p class="text-blue-6 text-center mb-20">
					You can select any 1 program from below list
				</p>
				<div class="dose-modal__cta mt-20">
					<button
						class="theme-btn theme-btn-size-lg theme-btn__secondary min-w-206 fw-400"
						>1 Month Programs</button
					>
					<button
						class="theme-btn theme-btn-size-lg theme-btn__outline theme-btn__outline--secondary min-w-206"
						>3 Month Programs</button
					>
				</div>
				<div class="modal__radios mt-20">
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$50</span
							>
						</label>
					</div>
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$50</span
							>
						</label>
					</div>
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$350</span
							>
						</label>
					</div>
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$350</span
							>
						</label>
					</div>
				</div>

				<div class="dose-modal__selection">
					<p class="fs-14">You have selected - 0.25mg - $299 </p>
				</div>
				<div class="modal__actions">
					<button
						class="modal__action modal__action--outline"
						data-dismiss="modal"
						type="button"
					>
						Cancel
					</button>
					<button class="modal__action modal__action--primary" type="button">
						Confirm
					</button>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Dose Modal End -->
