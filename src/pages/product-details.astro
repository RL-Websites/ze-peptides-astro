---
import ClientFeedback from "../components/ClientFeedback.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HowWorks from "../components/HowWorks.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<Header />
	<!-- =====|| Main Section Start ||====== -->
	<main class="page">
		<div class="page__wrapper page__wrapper--alt">
			<!-- ==|| Product Hero Section Start ||== -->
			<section class="product-hero">
				<div class="container-fluid px-0">
					<div class="row">
						<div class="col-lg-5 col-md-6 product-hero__left-col">
							<div class="product-hero__left product-hero__left--green">
								<div class="product-hero__img">
									<img
										src="Themes/Thrivewellrx.Theme.Slimout/assets/img/products/product-3.png"
										alt="Product"
									/>
								</div>
							</div>
						</div>
						<div class="col-lg-7 col-md-6 product-hero__right-col">
							<div class="product-hero__right">
								<h4 class="site__heading-four"> Semaglutide Oral Tablets</h4>
								<h6 class="site__heading-six mt-20">About the Product:</h6>
								<ul class="d-flex flex-column gap-20 mt-20">
									<li class="list__item__alt">
										<i class="icon-checked list__item__alt-icon text-white"></i>
										Doctors Appointment, Prescription and Medications Included
									</li>
									<li class="list__item__alt">
										<i class="icon-checked list__item__alt-icon text-white"></i>
										Fast Shipping
									</li>
									<li class="list__item__alt">
										<i class="icon-checked list__item__alt-icon text-white"></i>
										All Supplies Included
									</li>
									<li class="list__item__alt">
										<i class="icon-checked list__item__alt-icon text-white"></i>
										Unlimited Weight Loss Program Support
									</li>
									<li class="list__item__alt">
										<i class="icon-checked list__item__alt-icon text-white"></i>
										Bypass Insurance – No Insurance Needed
									</li>
									<li class="list__item__alt">
										<i class="icon-checked list__item__alt-icon text-white"></i>
										No Hidden Fees
									</li>
								</ul>

								<div class="product-hero__cart mt-30">
									<div class="product-action">
										<div class="input-group product-action__cart">
											<span class="input-group-btn">
												<button class="btn" type="button">
													<i class="icon-minus"></i>
												</button>
											</span>
											<input
												type="text"
												class="form-control"
												id="quantity"
												value="1"
											/>
											<span class="input-group-btn">
												<button class="btn" type="button">
													<i class="icon-plus1"></i>
												</button>
											</span>
										</div>

										<div class="product-action__btn">
											<!-- <button
             type="button"
             class="theme-btn theme-btn__primary theme-btn__primary--uppercase"
            >
             Out Of Stock
            </button> -->
											<button
												type="button"
												class="theme-btn theme-btn__outline theme-btn__outline--primary"
											>
												Buy Now
											</button>
											<button
												type="button"
												class="theme-btn theme-btn__primary"
											>
												Add to Cart
											</button>
										</div>
									</div>
								</div>

								<ul
									class="nav nav-pills nav-pills__custom mb-3"
									id="pills-tab"
									role="tablist"
								>
									<li class="nav-item" role="presentation">
										<button
											class="nav-link active"
											id="pills-home-tab"
											data-bs-toggle="pill"
											data-bs-target="#pills-home"
											type="button"
											role="tab"
											aria-controls="pills-home"
											aria-selected="true"
										>
											1 Month Program
										</button>
									</li>
									<li class="nav-item" role="presentation">
										<button
											class="nav-link"
											id="pills-profile-tab"
											data-bs-toggle="pill"
											data-bs-target="#pills-profile"
											type="button"
											role="tab"
											aria-controls="pills-profile"
											aria-selected="false">3 Month Program</button
										>
									</li>
								</ul>
								<div
									class="tab-content tab-content__custom"
									id="pills-tabContent"
								>
									<div
										class="tab-pane fade show active"
										id="pills-home"
										role="tabpanel"
										aria-labelledby="pills-home-tab"
									>
										<div class="tab-pills">
											<div class="tab-pills__single">
												<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
													>.50mg</span
												>
												<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
											</div>
											<div class="tab-pills__single">
												<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
													>500mg</span
												>
												<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$1099</span>
											</div>
											<div class="tab-pills__single">
												<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
													>.50mg</span
												>
												<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
											</div>
											<div class="tab-pills__single">
												<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
													>.50mg</span
												>
												<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
											</div>
											<div class="tab-pills__single">
												<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
													>.50mg</span
												>
												<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
											</div>
											<div class="tab-pills__single">
												<span class="fs-md-18 fs-sm-16 fs-14 lh-1 fw-bold"
													>.50mg</span
												>
												<span class="fs-md-16 fs-sm-14 fs-12 lh-1">$299</span>
											</div>
										</div>
									</div>
									<div
										class="tab-pane fade"
										id="pills-profile"
										role="tabpanel"
										aria-labelledby="pills-profile-tab">..3.</div
									>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>
			<!-- ==|| Product Section End ||== -->

			<!-- ==|| Benifits of Medicine Section Start ||== -->
			<section class="product product__benifits">
				<div class="container">
					<div class="section__title d-md-flex align-items-center gap-3">
						<h2 class="site__heading-two text-secondary text-capitalize"
							>Benefits of <br /> the medicine</h2
						>
						<div class="d-md-block d-none">
							<img
								src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/frame-with-title-green.svg"
								alt="frame "
							/>
						</div>
					</div>

					<div class="product__benifits__items mt-md-80 mt-30">
						<div class="row">
							<div class="col-md-4">
								<div class="product__benifits__item">
									<div class="product__benifits__img">
										<img
											src="Themes/Thrivewellrx.Theme.Slimout/assets/img/benifit-1.png"
											alt="Product Benifit"
										/>
									</div>
									<div class="product__benifits__content">
										<h6 class="site__heading-six">Enhanced <br /> Absorption</h6
										>
										<p class="mt-10"
											>Doctors will conduct an online medical consultation,
											which may include a video call or phone conversation.</p
										>
									</div>
								</div>
							</div>
							<div class="col-md-4">
								<div class="product__benifits__item">
									<div class="product__benifits__img">
										<img
											src="Themes/Thrivewellrx.Theme.Slimout/assets/img/benifit-1.png"
											alt="Product Benifit"
										/>
									</div>
									<div class="product__benifits__content">
										<h6 class="site__heading-six">Personalized <br /> Dosing</h6
										>
										<p class="mt-10"
											>Doctors will conduct an online medical consultation,
											which may include a video call or phone conversation.</p
										>
									</div>
								</div>
							</div>
							<div class="col-md-4">
								<div class="product__benifits__item">
									<div class="product__benifits__img">
										<img
											src="Themes/Thrivewellrx.Theme.Slimout/assets/img/benifit-1.png"
											alt="Product Benifit"
										/>
									</div>
									<div class="product__benifits__content">
										<h6 class="site__heading-six"
											>Comprehensive <br /> Support</h6
										>
										<p class="mt-10"
											>Doctors will conduct an online medical consultation,
											which may include a video call or phone conversation.</p
										>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>
			<!-- ==|| Benifits of Medicine Section End ||== -->

			<!-- ==|| Our Solution Section Start ||== -->
			<div class="product__solution">
				<div class="container">
					<div class="section__title d-md-flex align-items-center gap-3">
						<h2 class="site__heading-two text-white text-capitalize"
							>How our solution <br /> differs from others</h2
						>
						<div class="d-md-block d-none">
							<img
								class="site__heading-img"
								src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/frame-with-title-blue.svg"
								alt="frame "
							/>
						</div>
					</div>

					<div class="row">
						<div class="col-md-5 pr-md-30">
							<p class="fs-16 text-white mt-20"
								>Every day is the right time to begin building a life and body
								that feels powerful. Fortify Testosterone Booster is a potent,
								expertly designed blend developed to elevate your strength and
								vitality.</p
							>
						</div>
						<div class="col-md-7 mt-md-60">
							<div class="product__card--normal">
								<h6 class="site__heading-six">Exceptional Enhancement</h6>
								<p class="mt-10"
									>This proprietary blend was crafted by pharmacists to deliver
									a powerful impact you won’t find elsewhere. Discover Fortify</p
								>
							</div>

							<div class="product__card--normal mt-20">
								<h6 class="site__heading-six">Sharpened Focus</h6>
								<p class="mt-10"
									>Balanced testosterone supports increased stamina, resilience,
									cognitive clarity, stress balance, and improved memory.</p
								>
							</div>
							<div class="product__card--normal mt-20">
								<h6 class="site__heading-six">Mental Optimization</h6>
								<p class="mt-10"
									>Balanced testosterone supports increased stamina, resilience,
									cognitive clarity, stress balance, and improved memory.</p
								>
							</div>
							<div class="product__card--normal mt-20">
								<h6 class="site__heading-six">Boost Reproductive Health</h6>
								<p class="mt-10"
									>Balanced testosterone supports increased stamina, resilience,
									cognitive clarity, stress balance, and improved memory.</p
								>
							</div>
						</div>
					</div>
				</div>
			</div>
			<!-- ==|| Our Solution Section End ||== -->

			<!--===|| How it Works Section Start ||===-->
			<HowWorks />
			<!--===|| How it Works Section End ||===-->

			<!--===|| Client Feedback Section Start ||===-->
			<ClientFeedback />
			<!--===|| Client Feedback Section End ||===-->

			<!--===|| Faq Section Start ||===-->
			<section class="faq">
				<div class="container faq__wrapper">
					<div class="faq__frame--left">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/left-curve.svg"
							alt=""
						/>
					</div>
					<div class="faq__frame--tree">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/tree-frame.svg"
							alt=""
						/>
					</div>
					<div class="row">
						<div class="col-lg-5 faq__title">
							<div class="section__title d-lg-flex align-items-center gap-3">
								<h3
									class="site__heading-three text-secondary client__title text-capitalize text-lg-start text-center"
									>answers to popular questions</h3
								>
							</div>
						</div>
						<div class="col-lg-6 offset-lg-1 faq__items">
							<Faq />
						</div>
					</div>
				</div>
			</section>
			<!--===|| Faq Section End ||===-->

			<!--===|| CTA Section Start ||===-->
			<section class="cta">
				<div class="container">
					<div class="row">
						<div class="col-md-5 order-md-0 order-1 mt-md-0 mt-30">
							<img
								class="w-100"
								src="Themes/Thrivewellrx.Theme.Slimout/assets/img/cta.png"
								alt="CTA"
							/>
						</div>
						<div class="col-md-6 offset-md-1 order-md-1 order-0">
							<div class="cta__content-frame">
								<img
									class="img-fluid"
									src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/frame-with-title-blue.svg"
									alt="frame"
								/>
							</div>
							<h3
								class="site__heading-three text-white mt-10 text-md-start text-center"
								>100% Guranteed</h3
							>
							<p
								class="text-white fs-md-18 fs-sm-16 fs-14 fw-bold pr-md-60 pr-0 text-md-start text-center mt-md-20 mt-10"
								>Getting started is simple. Our process is designed to be
								smooth, transparent, and hassle-free—so you can focus on what
								matters most.</p
							>
							<div
								class="d-flex justify-content-md-start justify-content-center"
							>
								<button
									type="button"
									class="theme-btn theme-btn__light"
									data-bs-toggle="modal"
									data-bs-target="#unableProceed"
									class="theme-btn theme-btn__primary theme-btn__primary--icon mt-lg-40 mt-10"
									>Get Started <i class="icon-arrow"></i>
								</button>
							</div>
						</div>
					</div>
				</div>
			</section>
			<!--===|| CTA Section End ||===-->
		</div>
	</main>
	<!-- =====|| Main Section End ||====== -->
</Layout>

<Footer />

<!-- Dose Modal Start -->
<div id="doses" class="modal fade dose-modal" tabindex="-1" role="dialog">
	<div class="modal-dialog" role="document">
		<div class="modal-content">
			<!-- <button type="button" class="btn-close" data-dismiss="modal">
				<i class="icon-cross_filled"></i>
			</button> -->

			<div class="modal-body">
				<div class="modal__text mt-0">
					<p>Select Program</p>
				</div>
				<p class="text-blue-6 text-center mb-20">
					You can select any 1 program from below list
				</p>
				<div class="dose-modal__cta mt-20">
					<button
						class="theme-btn theme-btn-size-lg theme-btn__secondary min-w-206 fw-400"
						>1 Month Programs</button
					>
					<button
						class="theme-btn theme-btn-size-lg theme-btn__outline theme-btn__outline--secondary min-w-206"
						>3 Month Programs</button
					>
				</div>
				<div class="modal__radios mt-20">
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$50</span
							>
						</label>
					</div>
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$50</span
							>
						</label>
					</div>
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$350</span
							>
						</label>
					</div>
					<div class="modal__radios-item">
						<label class="dose-radio">
							<span class="dose-radio__input">
								<input name="dose" type="radio" />
								<span></span>
							</span>
							<span
								class="dose-radio__label"
								data-bind="text: dose.Dose +'/$'+dose.Price">2.5mg/$350</span
							>
						</label>
					</div>
				</div>

				<div class="dose-modal__selection">
					<p class="fs-14">You have selected - 0.25mg - $299 </p>
				</div>
				<div class="modal__actions">
					<button
						class="modal__action modal__action--outline"
						data-dismiss="modal"
						type="button"
					>
						Cancel
					</button>
					<button class="modal__action modal__action--primary" type="button">
						Confirm
					</button>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Dose Modal End -->
