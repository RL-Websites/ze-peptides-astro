---
import ClientFeedback from "../components/ClientFeedback.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Homehero from "../components/homePage/homehero.astro";
import HowWorks from "../components/HowWorks.astro";
import ProductCard from "../components/ProductCard.astro";
import Toast from "../components/Toast.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<!--=====|| Main Section Start ||=====-->
	<main class="page">
		<!--===|| Banner Section Start ||===-->
		<Header />
		<!-- <section class="home__hero home__hero__header">
		</section> -->
		<Homehero />
		<!--===|| Banner Section End ||===-->

		<!-- <div class="ebook__download">
			<button class="ebook__download__btn">
				<div class="ebook__download__img">
					<img
						src="Themes/Thrivewellrx.Theme.Slimout/assets/img/e-book.svg"
						alt="E-Book"
					/>
				</div>
				<span class="ebook__download__content">Download Free E Book</span>
			</button>
		</div> -->

		<!--===|| Product Section Start ||===-->
		<section class="product">
			<div class="container">
				<div class="section__title d-md-flex align-items-center gap-3">
					<h2 class="site__heading-two text-secondary product__title"
						>Range Of Products</h2
					>
					<div class="d-md-block d-none">
						<img
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/frame-with-title-green.svg"
							alt="frame "
						/>
					</div>
				</div>

				<ProductCard />
			</div>
		</section>
		<!--===|| Product Section End ||===-->

		<!--===|| How it Works Section Start ||===-->
		<HowWorks />
		<!--===|| How it Works Section End ||===-->

		<!--===|| Client Feedback Section Start ||===-->
		<ClientFeedback />
		<!--===|| Client Feedback Section End ||===-->

		<!--===|| Faq Section Start ||===-->
		<section class="faq">
			<div class="container faq__wrapper">
				<div class="faq__frame--left">
					<img
						src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/left-curve.svg"
						alt=""
					/>
				</div>
				<div class="faq__frame--tree">
					<img
						src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/tree-frame.svg"
						alt=""
					/>
				</div>
				<div class="row">
					<div class="col-lg-5 faq__title">
						<div class="section__title d-lg-flex align-items-center gap-3">
							<h3
								class="site__heading-three text-secondary client__title text-capitalize text-lg-start text-center"
								>answers to popular questions</h3
							>
						</div>
					</div>
					<div class="col-lg-6 offset-lg-1 faq__items">
						<Faq />
					</div>
				</div>
			</div>
		</section>
		<!--===|| Faq Section End ||===-->

		<!--===|| CTA Section Start ||===-->
		<section class="cta">
			<div class="container">
				<div class="row">
					<div class="col-md-5 order-md-0 order-1 mt-md-0 mt-30">
						<img
							class="w-100"
							src="Themes/Thrivewellrx.Theme.Slimout/assets/img/cta.png"
							alt="CTA"
						/>
					</div>
					<div class="col-md-6 offset-md-1 order-md-1 order-0">
						<div class="cta__content-frame">
							<img
								class="img-fluid"
								src="Themes/Thrivewellrx.Theme.Slimout/assets/img/frame/frame-with-title-blue.svg"
								alt="frame"
							/>
						</div>
						<h3
							class="site__heading-three text-white mt-10 text-md-start text-center"
							>100% Guranteed</h3
						>
						<p
							class="text-white fs-md-18 fs-sm-16 fs-14 fw-bold pr-md-60 pr-0 text-md-start text-center mt-md-20 mt-10"
							>Getting started is simple. Our process is designed to be smooth,
							transparent, and hassle-free—so you can focus on what matters
							most.</p
						>
						<div class="d-flex justify-content-md-start justify-content-center">
							<button
								type="button"
								class="theme-btn theme-btn__light"
								data-bs-toggle="modal"
								data-bs-target="#unableProceed"
								class="theme-btn theme-btn__primary theme-btn__primary--icon mt-lg-40 mt-10"
								>Get Started <i class="icon-arrow"></i>
							</button>
						</div>
					</div>
				</div>
			</div>
		</section>
		<!--===|| CTA Section End ||===-->

		<!--=====|| Main Section End ||=====-->
	</main>

	<!-- =====|| Toast Start ||====== -->
	<Toast />
	<!-- =====|| Toast Start ||====== -->

	<Footer />
</Layout>

<!--Unable To Proceed Start -->
<div
	id="unableProceed"
	class="modal fade dose-modal"
	tabindex="-1"
	aria-labelledby="exampleModalLabel"
	aria-hidden="true"
>
	<div class="modal-dialog" role="document">
		<div class="modal-content">
			<!-- <button type="button" class="btn-close" data-dismiss="modal">
				<i class="icon-cross_filled"></i>
			</button> -->

			<div class="modal-body">
				<div class="modal__text mt-0">
					<i class="icon-alert fs-md-90 fs-70"></i>
					<h5 class="site__heading-five fw-bold text-secondary text-center"
						>We're Unable to Proceed with Your Treatment
					</h5>
				</div>
				<p class="text-blue-6 text-center mb-20 fs-md-18 fs-16 mt-md-30 mt-10">
					<span class="fw-bold">Your BMI is 21.25.</span> Based on the medical information
					you’ve provided, it appears that you may have a condition that makes treatment
					with GLP-1 medications unsafe at this time. For your safety, we recommend
					consulting with your personal healthcare provider before pursuing any weight
					loss treatments.
				</p>

				<div class="modal__actions">
					<button
						class="modal__action modal__action--outline"
						data-bs-dismiss="modal"
						aria-label="Close"
						type="button"
					>
						Cancel
					</button>
					<button class="modal__action modal__action--primary" type="button">
						Confirm
					</button>
				</div>
			</div>
		</div>
	</div>
</div>
<!--Unable To Proceed End -->
