---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<Header />

	<!-- =====|| Main Section Start ||====== -->

	<main class="page">
		<section class="login py-5">
			<div class="container p-0">
				<div class="row justify-content-center mt-120 mt-sm-150 mx-0">
					<div class="col-11 col-sm-10 col-md-8 col-lg-8">
						<div class="login__header text-center mb-30">
							<div class="col-12 text-center">
								<h1 class="text-primary-grad-1 mb-0">Forgot password</h1>
							</div>
						</div>
					</div>

					<form class="container">
						<div class="row justify-content-center mx-0">
							<div class="col-11 col-sm-10 col-md-8 col-lg-5 px-md-30 px-0">
								<div class="condition__highlight">
									<p class="text-body1 black"
										>If you forgot your password an email with a password reset
										link will be sent to you. Click on the link in that email
										and you will be taken to a page where you can then create a
										new password.</p
									>
								</div>

								<label for="email" class="basic-label mt-3">
									Email Address <span class="icon-ellipse"></span>
								</label>
								<input
									type="email"
									class="basic-input form-control"
									id="email"
									required
								/>
								<p class="basic-error">Email is required!</p>

								<button
									type="submit"
									class="theme-btn theme-btn__primary w-100 mb-4 mt-3"
								>
									Send Reset Link
								</button>

								<div class="text-center mt-3">
									<span>Already have an account?</span>
									<button
										class="text-decoration-underline theme-btn theme-btn__accent text-primary"
									>
										Log In</button
									>
									<p class="mt-3 mb-60">
										First-time Visitor? <button
											class="text-decoration-underline theme-btn theme-btn__accent text-primary"
											>Create an account</button
										>
									</p>
								</div>
							</div>
						</div>
					</form>
				</div>
			</div>
		</section>
		<!-- ==|| Login Section End ||== -->
	</main>

	<Footer />
</Layout>
