---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<Header />

	<!-- =====|| Main Section Start ||====== -->

	<main class="page">
		<!-- ==|| Login Section Start ||== -->
		<section class="forgot-password py-5">
			<div class="row justify-content-center mt-150 mt-sm-100 mx-0">
				<div class="max-w-600">
					<div
						class="forgot-password__header text-center mb-60 col-12 col-md-12"
					>
						<h1 class="text-primary-grad-1">Forgot Password</h1>
					</div>
				</div>

				<form>
					<div class="row justify-content-center mx-0">
						<div
							class="col-11 col-sm-10 col-md-8 col-lg-6 px-md-30 px-0 max-w-500"
						>
							<div class="condition__highlight">
								<p class="text-body1 black"
									>If you forgot your password an email with a password reset
									link will be sent to you. Click on the link in that email and
									you will be taken to a page where you can then create a new
									password.</p
								>
							</div>

							<label for="email" class="basic-label mt-3">
								Email Address <span class="icon-ellipse"></span>
							</label>
							<input
								type="email"
								class="basic-input form-control"
								id="email"
								required
							/>
							<div class="invalid-feedback">Please enter a valid email.</div>

							<button
								type="submit"
								class="theme-btn theme-btn__primary w-100 mb-4 mt-3"
							>
								Send Reset Link
							</button>

							<div class="text-center mt-3">
								<span>Already have an account?</span>
								<a href="#" class="text-decoration-underline"> Log In</a>
								<p class="mt-3">
									First-time Visitor? <a
										href="#"
										class="text-decoration-underline">Create an account</a
									>
								</p>
							</div>
						</div>
					</div>
				</form>
			</div>
		</section>
	</main>
	<!-- ==|| Login Section End ||== -->
</Layout>

<Footer />
