---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Toast from "../components/Toast.astro";
import Layout from "../layouts/Layout.astro";
import StateAutocomplete from "../components/StateAutocomplete.astro";
---

<Layout>
  <Header />

  <!-- =====|| Main Section Start ||====== -->
  <main class="page">
    <div class="page__wrapper page__wrapper--alt">
      <!-- ==|| Cart Hero Section Start ||== -->
      <section class="cart-hero pt-md-130 pt-120">
        <div class="container" data-aos="fade-up" data-aos-duration="1000">
          <h1 class="text-primary-grad-1 text-center">Payment Method</h1>
        </div>
      </section>
      <!-- ==|| Cart Hero Section End ||== -->

      <!-- ==|| Payment List Section Start ||== -->
      <section class="payment__card">
        <div class="container">
          <div
            class="m-0 cart-card payment__card--cart-summary"
            data-aos="fade-up"
            data-aos-duration="1000"
          >
            <div class="container">
              <div class="row mb-3">
                <div class="payment-table-header">
                  <div class="col-md-6">Payment Options</div>
                  <div class="col-md-3">Name On Card</div>
                  <div class="col-md-3">Expires</div>
                </div>
              </div>

              <div class="row align-items-center payment-table mb-3">
                <div class="payment-table-body d-md-flex fs-18">
                  <div class="col-md-6">
                    <div class="d-flex align-items-center gap-2">
                      <div class="form-check">
                        <input
                          class="form-check-input fs-24"
                          type="radio"
                          name="paymentMethod"
                          id="cardVisa"
                          value="visa"
                          checked
                        />
                      </div>
                      <div class="card-image">
                        <img
                          src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/visa.png"
                          alt="Visa"
                        />
                      </div>
                      <span class="card-image__text">(****1390)</span>
                      <span class="status-pill status-pill--submitted"
                        >Default</span
                      >
                    </div>
                  </div>
                  <div class="col-md-3 table-my">
                    <p class="fs-22 fw-medium payment-table-title">
                      Name On Card
                    </p>
                    <p class="fs-18">Dean Jones</p>
                  </div>
                  <div class="col-md-3 table-my">
                    <p class="fs-22 fw-medium payment-table-title">Expires</p>
                    <p class="fs-18">11/2026</p>
                  </div>
                </div>
              </div>

              <div class="row align-items-center mb-3">
                <div class="payment-table-body p-24 d-md-flex fs-18">
                  <div class="col-md-6">
                    <div class="d-flex align-items-center gap-2">
                      <div class="form-check">
                        <input
                          class="form-check-input fs-24"
                          type="radio"
                          name="paymentMethod"
                          id="cardMaster"
                          value="master"
                        />
                      </div>
                      <div class="card-image">
                        <img
                          src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/master.png"
                          alt="MasterCard"
                        />
                      </div>
                      <span class="card-image__text">(****2467)</span>
                      <span class="status-pill">Make Default</span>
                    </div>
                  </div>
                  <div class="col-md-3 table-my">
                    <p class="fs-22 fw-medium payment-table-title">
                      Name On Card
                    </p>
                    <p class="fs-18">Dean Jones</p>
                  </div>
                  <div class="col-md-3 table-my">
                    <p class="fs-22 fw-medium payment-table-title">Expires</p>
                    <p class="fs-18">11/2026</p>
                  </div>
                </div>
              </div>

              <div class="row align-items-center mb-3">
                <div class="payment-table-body p-24 d-md-flex fs-18">
                  <div class="col-md-6">
                    <div class="d-flex align-items-center gap-2">
                      <div class="form-check">
                        <input
                          class="form-check-input fs-24"
                          type="radio"
                          name="paymentMethod"
                          id="cardAmex"
                          value="amex"
                        />
                      </div>
                      <div class="card-image">
                        <img
                          src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/amex.png"
                          alt="Amex"
                        />
                      </div>
                      <span class="card-image__text">(****1390)</span>
                      <span class="status-pill status-pill--warning"
                        >Expired</span
                      >
                    </div>
                  </div>
                  <div class="col-md-3 table-my">
                    <p class="fs-22 fw-medium payment-table-title">
                      Name On Card
                    </p>
                    <p class="fs-18">Dean Jones</p>
                  </div>
                  <div class="col-md-3 table-my">
                    <p class="fs-22 fw-medium payment-table-title">Expires</p>
                    <p class="fs-18">11/2026</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="ml-30">
              <label class="d-flex align-items-center">
                <div class="form-check">
                  <input
                    class="form-check-input fs-24"
                    type="radio"
                    name="DebitCard"
                    id="DebitCard"
                    value="debit"
                    checked
                  />
                </div>
                <span class="custom-check__label fs-18 fw-bold">
                  New Credit/Debit Card
                </span>
              </label>
            </div>
            <div class="col-12">
              <div class="payment-card__body">
                <div
                  class="payment__form payment__form--body payment__form--card"
                  id="payment-form"
                >
                  <div
                    class="payment__form--inline-fields payment__form--inline-fields--alt mt-20"
                  >
                    <div class="form-group">
                      <div class="d-flex items-start">
                        <label class="fw-bold mb-5 basic-label" for="cardNumber"
                          >Card Number<span class="icon-ellipse"></span></label
                        >
                        <div class="card-icons d-md-none d-flex ml-auto">
                          <img
                            src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/visa.png"
                            alt="Visa"
                          />
                          <img
                            src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/master.png"
                            alt="Mastercard"
                          />
                          <img
                            src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/amex.png"
                            alt="AMEX"
                          />
                          <img
                            src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/jcb.png"
                            alt="JCB"
                          />
                        </div>
                      </div>

                      <div class="payment__form--card-variation">
                        <input
                          inputmode="numeric"
                          class="basic-input card-input"
                          type="text"
                          id="cardNumber"
                          placeholder="1234 1234 1234 1234"
                        />
                        <div class="card-icons d-md-flex d-none">
                          <img
                            src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/visa.png"
                            alt="Visa"
                          />
                          <img
                            src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/master.png"
                            alt="Mastercard"
                          />
                          <img
                            src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/amex.png"
                            alt="AMEX"
                          />
                          <img
                            src="Themes/Thrivewellrx.Theme.ZePeptides/assets/img/payment/jcb.png"
                            alt="JCB"
                          />
                        </div>
                      </div>
                    </div>

                    <div class="form-group">
                      <label class="fw-bold mb-5 basic-label" for="expiry"
                        >Expiration Date<span class="icon-ellipse"
                        ></span></label
                      >
                      <input
                        inputmode="numeric"
                        class="basic-input"
                        type="text"
                        id="expiry"
                        placeholder="MM/YY"
                      />
                    </div>

                    <div class="form-group">
                      <label class="fw-bold mb-5 basic-label" for="cvc"
                        >Security Code<span class="icon-ellipse"></span></label
                      >
                      <input
                        inputmode="numeric"
                        class="basic-input"
                        type="text"
                        id="cvc"
                        placeholder="CVC"
                      />
                    </div>
                    <div class="select__items mb-0">
                      <label class="fw-bold mb-5 basic-label" for="country"
                        >Country<span class="icon-ellipse"></span></label
                      >
                      <select
                        class="select__options select__options-country text-secondary fw-normal"
                        name="country"
                        id="country"
                      >
                        <option value="">Select a country</option>
                        <option value="Afghanistan">Bangladesh</option>
                        <option value="Albania">India</option>
                        <option value="Algeria">Pakistan</option>
                        <option value="Andorra">USA</option>
                        <option value="Angola">Canada</option>
                      </select>
                    </div>

                    <div class="form-group">
                      <label
                        class="fw-bold mb-5 basic-label table-my"
                        for="zipCode"
                      >
                        ZIP Code<span class="icon-ellipse"></span>
                      </label>
                      <input
                        class="basic-input"
                        type="text"
                        id="zipCode"
                        placeholder="Enter ZIP code"
                        maxlength="5"
                      />
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="ml-24 mb-24">
              <label class="custom-check d-flex align-items-center">
                <span class="custom-check__input custom-check__input--alt">
                  <input type="checkbox" />
                  <span class="black-icon"></span>
                </span>
                <span class="custom-check__label"> Save this Information </span>
              </label>
            </div>
          </div>
        </div>
      </section>
      <!-- ==|| Payment List Section End ||== -->

      <section class="mt-40">
        <div class="container">
          <div class="row">
            <div class="col-12 payment__card--right">
              <div
                class="cart-card"
                data-aos="fade-left"
                data-aos-duration="1000"
                data-aos-delay="200"
              >
                <div class="cart-card__header">
                  <h3 class="fs-md-24 fs-20 fw-bold">
                    Cart Total <span class="fs-16 fw-normal">(4 items)</span>
                  </h3>
                </div>
                <div class="cart-card__body">
                  <div class="pricing__basic">
                    <div class="pricing__item">
                      <p class="pricing__item--name">Subtotal</p>
                      <p class="pricing__item--value">$150.50</p>
                    </div>
                    <div class="pricing__item">
                      <p class="pricing__item--name">Shipping</p>
                      <p class="pricing__item--value">$30.50</p>
                    </div>
                    <!-- <div class="pricing__item">
                                                <p class="pricing__item--name">Consultancy Fee</p>
                                                <p class="pricing__item--value">$30.50</p>
                                            </div> -->
                  </div>

                  <div class="pricing__total">
                    <div class="pricing__item">
                      <p class="pricing__item--name">Discount</p>
                      <p class="pricing__item--value text-dark-red-2">-$5.50</p>
                    </div>

                    <div class="pricing__total-item">
                      <p class="pricing__total--name">Total</p>
                      <p class="pricing__total--value">$175.87</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ==|| Shipping info Section Start ||== -->
      <section class="mt-40" data-aos="fade-up" data-aos-duration="1000">
        <div class="container">
          <div class="payment__card mt-0">
            <div class="payment__header">
              <h3 class="fs-md-24 fs-18 fw-bold">Shipping Info</h3>

              <!-- <div>
                <label class="custom-check d-flex align-items-center">
                  <span class="custom-check__input custom-check__input--alt">
                    <input type="checkbox" />
                    <span class="black-icon"></span>
                  </span>
                  <span class="custom-check__label">
                    Save this Information
                  </span>
                </label>
              </div> -->
            </div>
            <div class="payment__body">
              <div class="payment__form">
                <form>
                  <div class="payment__wrapper">
                    <div class="payment__input">
                      <label class="basic-label" for="shippingName"
                        >Name <span class="icon-ellipse"></span></label
                      >
                      <input
                        class="basic-input"
                        type="text"
                        name="shippingName"
                        id="shippingName"
                        placeholder=""
                      />
                      <p class="basic-error">Shipping name is required</p>
                    </div>
                    <div class="payment__input">
                      <label class="basic-label" for="shippingState"
                        >State <span class="icon-ellipse"></span></label
                      >
                      <StateAutocomplete
                        id="shippingState"
                        name="shippingState"
                        className="select__options select__options--padding fs-16 text-secondary"
                      />
                    </div>
                    <div class="payment__input">
                      <label class="basic-label" for="shippingAddress"
                        >Address <span class="icon-ellipse"></span></label
                      >
                      <input
                        class="basic-input"
                        type="email"
                        name="shippingAddress"
                        id="shippingAddress"
                      />
                    </div>

                    <div class="payment__input">
                      <label class="basic-label" for="shippingAddress"
                        >City <span class="icon-ellipse"></span></label
                      >
                      <input
                        class="basic-input"
                        type="email"
                        name="shippingAddress"
                        id="shippingAddress"
                      />
                    </div>
                    <div class="payment__input">
                      <label class="basic-label" for="shippingZipCode"
                        >Zip Code <span class="icon-ellipse"></span></label
                      >
                      <input
                        inputmode="numeric"
                        class="basic-input"
                        type="text"
                        name="shippingZipCode"
                        id="shippingZipCode"
                      />
                    </div>
                    <div class="payment__input">
                      <label class="basic-label" for="shippingEmail"
                        >Email Address <span class="icon-ellipse"></span></label
                      >
                      <input
                        class="basic-input"
                        type="email"
                        name="shippingEmail"
                        id="shippingEmail"
                      />
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- ==|| Shipping info Section End ||== -->

      <!-- ==|| Billing Section Start ||== -->
      <section
        class="payment__billing mt-50 mt-md-100"
        data-aos="fade-up"
        data-aos-duration="1000"
      >
        <div class="container">
          <div class="payment__card mt-0">
            <div class="payment__header">
              <h3 class="fs-md-24 fs-20 fw-bold">Billing Info</h3>

              <div>
                <label class="custom-check">
                  <span class="custom-check__input custom-check__input--alt">
                    <input type="checkbox" />
                    <span class="black-icon"></span>
                  </span>
                  <span class="custom-check__label">
                    Same as shipping Information
                  </span>
                </label>
                <label class="custom-check ml-20">
                  <span class="custom-check__input custom-check__input--alt">
                    <input type="checkbox" />
                    <span class="black-icon"></span>
                  </span>
                  <span class="custom-check__label">
                    Save this Information
                  </span>
                </label>
              </div>
            </div>
            <div class="payment__body">
              <div class="payment__form">
                <form>
                  <div class="payment__wrapper">
                    <div class="payment__input">
                      <label class="basic-label" for="shippingName"
                        >Name <span class="icon-ellipse"></span></label
                      >
                      <input
                        class="basic-input"
                        type="text"
                        name="shippingName"
                        id="shippingName"
                      />
                    </div>
                    <div class="payment__input">
                      <label class="basic-label" for="billingState"
                        >State <span class="icon-ellipse"></span></label
                      >
                      <StateAutocomplete
                        id="billingState"
                        name="billingState"
                        className="select__options select__options--padding fs-16 text-secondary"
                      />
                    </div>
                    <div class="payment__input">
                      <label class="basic-label" for="billingAddress"
                        >Address <span class="icon-ellipse"></span></label
                      >
                      <input
                        class="basic-input"
                        type="email"
                        name="billingAddress"
                        id="billingAddress"
                      />
                    </div>

                    <div class="payment__input">
                      <label class="basic-label" for="billingCity"
                        >City <span class="icon-ellipse"></span></label
                      >
                      <input
                        class="basic-input"
                        type="email"
                        name="billingCity"
                        id="billingCity"
                      />
                    </div>
                    <div class="payment__input">
                      <label class="basic-label" for="billingZipCode"
                        >Zip Code <span class="icon-ellipse"></span></label
                      >
                      <input
                        inputmode="numeric"
                        class="basic-input"
                        type="text"
                        name="billingZipCode"
                        id="billingZipCode"
                      />
                    </div>
                    <div class="payment__input">
                      <label class="basic-label" for="billingEmail"
                        >Email Address <span class="icon-ellipse"></span></label
                      >
                      <input
                        class="basic-input"
                        type="email"
                        name="billingEmail"
                        id="billingEmail"
                      />
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>

          <!-- <div class="condition__highlight mt-50">
						<p class="mb-0"
							>This product is not dispensed without intake review and provider
							clearance.</p
						>
					</div> -->
          <!-- <div class="mt-30">
						<label class="custom-check mt-15">
							<span class="custom-check__input">
								<input
									type="checkbox"
									data-bind="checked: hasAnsweredTruthfully"
								/>
								<span></span>
							</span>

							<span class="custom-check__label">
								I confirm that all information associated with my treatment is
								accurate and that I understand these products must be used only
								under the supervision of a licensed healthcare provider.
							</span>
						</label>
						<p
							class="basic-error"
							data-bind="visible: isSubmitted, validationMessage: hasAnsweredTruthfully"
						></p>
					</div> -->

          <div>
            <label class="custom-check mt-15">
              <span class="custom-check__input">
                <!--<input type="checkbox" data-bind="checked: agreedToTermsAndConditions" />-->
                <input
                  type="checkbox"
                  data-bs-toggle="modal"
                  data-bs-target="#termCodition"
                  checked
                />
                <span></span>
              </span>

              <span class="custom-check__label">
                Please read the <span class="text-primary"
                  >Terms & Conditions</span
                >—purchase cannot be completed without your acknowledgment.
              </span>
            </label>
            <p
              class="basic-error"
              data-bind="visible: isSubmitted, validationMessage: agreedToTermsAndConditions"
            >
            </p>
          </div>

          <div class="step-btn text-end mt-40">
            <button
              type="button"
              class="theme-btn theme-btn__outline theme-btn__outline--primary cursor-pointer theme-btn__min-w-210"
            >
              Go Back
            </button>
            <button
              type="button"
              class="theme-btn theme-btn__primary theme-btn__min-w-210 theme-btn__primary--signin theme-btn--with-loader"
              data-bs-toggle="modal"
              data-bs-target="#payment"
            >
              Next

              <span class="theme-btn__loader spin"></span>
            </button>
          </div>
        </div>
      </section>
      <!-- ==|| Billing Section End ||== -->
    </div>
  </main>
  <!-- =====|| Main Section End ||====== -->

  <!-- =====|| Payment Successful Modal Start ||====== -->
  <div
    id="payment"
    class="modal fade payment-modal confirm-modal"
    tabindex="-1"
    aria-labelledby="payment"
    aria-hidden="true"
  >
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <!-- <button type="button" class="btn-close" data-dismiss="modal">
					<i class="icon-cross_filled"></i>
				</button> -->

        <div class="modal-body">
          <div class="modal__icon">
            <i class="icon-tick-outlined"></i>
          </div>
          <div class="modal__text">
            <h5 class="site__heading-five fw-bold text-secondary text-center">
              Payment Successful
            </h5>
          </div>

          <p
            class="text-blue-6 text-center mb-20 fs-md-18 fs-16 mt-md-30 mt-10"
          >
            Thank you for your payment. Your order is now being processed. If
            necessary, a prescriber will contact you to discuss the next steps
            in your treatment.
          </p>
          <p class="modal__highlight-text">
            This product requires a lab test for proper evaluation. We will send
            you a lab test kit, or you can choose to visit our nearest lab for
            testing. Once the test results are available, we will proceed with
            the next steps in your treatment.
          </p>

          <div class="modal__actions">
            <button
              class="modal__action modal__action--outline"
              type="button"
              data-bs-dismiss="modal"
              aria-label="Close"
            >
              I Will Do It Later
            </button>
            <button class="modal__action modal__action--primary" type="button">
              Upload Documents
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- =====|| Payment Successful Modal End ||====== -->

  <!-- =====|| Toast Start ||====== -->
  <Toast />
  <!-- =====|| Toast Start ||====== -->

  <!-- Terms & Condition Modal Start -->
  <div
    id="termCodition"
    class="modal fade terms-condition-modal"
    tabindex="-1"
    role="dialog"
  >
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <!-- <button type="button" class="btn-close-filled" data-dismiss="modal">
					<i class="icon-cross_filled"></i>
				</button> -->

        <div class="modal-header">
          <h2 class="section__title">Terms and Conditions</h2>
        </div>

        <div class="modal-body">
          <div class="container px-4">
            <div class="mt-md-10 mt-20">
              <h6 class="fs-md-24 fs-18 text-black fw-bold">
                Important Legal Notice
              </h6>
              <p class="fs-md-18 fs-16 fw-400 mt-20">
                By purchasing from PeptideLab, you acknowledge that all products
                are for research purposes only and agree to comply with all
                terms outlined below. These terms constitute a legally binding
                agreement.
              </p>
            </div>

            <div class="mt-md-40 mt-20">
              <h6 class="fs-md-24 fs-18 text-black fw-bold">
                1. Acceptance of Terms
              </h6>
              <p class="fs-md-18 fs-16 fw-400 mt-20">
                By accessing or using PeptideLab's website and purchasing our
                products, you agree to be bound by these Terms and Conditions.
                If you do not agree with any part of these terms, you must not
                use our website or purchase our products.
              </p>

              <p class="fs-md-18 fs-16 fw-400 mt-20">
                These terms constitute a legally binding agreement between you
                and PeptideLab. We reserve the right to modify these terms at
                any time, and such modifications shall be effective immediately
                upon posting on our website.
              </p>
            </div>

            <div class="mt-md-40 mt-20">
              <h6 class="fs-md-24 fs-18 text-black fw-bold">
                2. Research Use Only
              </h6>
              <p class="fs-md-18 fs-16 fw-400 mt-20">
                ALL PRODUCTS ARE SOLD STRICTLY FOR LABORATORY AND RESEARCH
                PURPOSES ONLY.
              </p>
              <p class="fs-md-18 fs-16 fw-400 mt-20">
                Our peptides and research chemicals are NOT intended for:
              </p>
              <ul class="list-disc">
                <li>Human consumption or self-administration</li>
                <li>Therapeutic, diagnostic, or medical use</li>
                <li>Administration to animals (in-vivo applications)</li>
                <li>Use as food additives or dietary supplements</li>
                <li>Any application outside legitimate scientific research</li>
              </ul>

              <p class="fs-md-18 fs-16 fw-400 mt-20">
                By purchasing, you acknowledge and warrant that you will use
                products exclusively for qualified research purposes in
                appropriate laboratory settings.
              </p>
            </div>

            <div class="mt-md-40 mt-20">
              <h6 class="fs-md-24 fs-18 text-black fw-bold">
                3. Age Verification & Eligibility
              </h6>
              <p class="fs-md-18 fs-16 fw-400 mt-20">
                You must be at least 18 years of age to purchase from
                PeptideLab. By placing an order, you represent and warrant that:
