---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<Header />

	<main class="page">
		<section class="reset-password">
			<div class="rounded-4">
				<div class="text-center">
					<h1 class="mb-1 text-primary-grad-1">Reset Password</h1>
				</div>

				<form class="reset-form">
					<div class="w-full mb-3">
						<label for="email" class="basic-label">Email Address</label>
						<p >John_07@gmail.com</p>
						<div class="invalid-feedback">Please enter a valid email.</div>
					</div>

					<!-- New Password Field -->
					<div class="w-full mb-3">
						<label for="new_password" class="basic-label">New Password</label>
						<input
							type="password"
							class="basic-input pe-5"
							id="new_password"
							required
						/>
						<i
							class="icon-StateOn"
							id="toggleNewPassword"
						></i>
						<div class="invalid-feedback">Password must not be empty.</div>
					</div>

					<!-- Confirm Password Field -->
					<div class="w-full mb-3 ">
						<label for="confirm_password" class="basic-label"
							>Confirm Password</label
						>
						<input
							type="password"
							class="basic-input pe-5"
							id="confirm_password"
							required
						/>
						<i
							class="icon-StateOn"
							id="toggleConfirmPassword"
							></i>
						<div class="invalid-feedback">Passwords must match.</div>
					</div>

					<div class="">
						<button
							type="submit"
							class="theme-btn theme-btn__primary w-100 btn-lg mb-4"
						>
							Change Password
						</button>

						<div class="text-center mt-3">
							<span>Already have an account?</span>
							<a
								href="#"
								class="text-decoration-underline forgot-text"
								>Log In</a
							>
							<p class=" mt-3">
								First-time Visitor?
								<a
									href="#"
									class="text-decoration-underline fw-medium"
									>Create an account</a
								>
							</p>
						</div>
					</div>
				</form>
			</div>
		</section>
	</main>
