---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<Header />

	<!-- =====|| Main Section Start ||====== -->
	<main class="page">
		<div class="page__wrapper page__wrapper--alt">
			<!-- ==|| Contact Section Start ||== -->
			<section class="contact">
				<div class="container">
					<h2 class="site__heading-four text-secondary text-center">
						Contact Us!
					</h2>
					<div class="contact__banner">
						<p class="fs-22 fw-medium mb-0">Message us:</p>
						<!-- <button class="theme-btn theme-btn__outline">Fastest</button> -->
					</div>
					<p class="my-30 text-center">Response typically under 24 hours.</p>
					<div class="row">
						<div class="col-md-4">
							<div class="contact__single">
								<span
									class="theme-btn theme-btn__outline theme-btn__outline--secondary contact--btn cursor-default fw-600"
								>
									Call Us</span
								>
								<p class="contact--text"
									>We're available 24/7, 7 days a week.
									<span class="fw-600">+1 (775) (xxx)-xxxx</span>
								</p>
							</div>
						</div>
						<div class="col-md-4">
							<div class="contact__single">
								<span
									class="theme-btn theme-btn__outline theme-btn__outline--secondary contact--btn cursor-default fw-600"
								>
									Write Us</span
								>
								<p class="contact--text"
									>Fill out our form and we will contact you within 24 hours.
									<span class="fw-600">Email: info@nexgen-wellness.com</span>
								</p>
							</div>
						</div>
						<div class="col-md-4">
							<div class="contact__single">
								<span
									class="theme-btn theme-btn__outline theme-btn__outline--secondary contact--btn cursor-default fw-600"
								>
									Mail Us</span
								>
								<p class="contact--text fw-600"
									>10152 Indiantown Rd, #181 Jupiter, FL 33478</p
								>
							</div>
						</div>
					</div>

					<form class="contact__form">
						<div class="single-input">
							<label class="single-input__label" for="name"
								>Your Name <span class="text-orange">*</span></label
							>
							<input
								class="single-input__field"
								type="text"
								id="name"
								name="name"
								placeholder="Your name"
								required
							/>
						</div>

						<div class="single-input">
							<label class="single-input__label" for="email"
								>Your Email <span class="text-orange">*</span></label
							>
							<input
								class="single-input__field"
								type="email"
								id="email"
								name="email"
								placeholder="Email address"
								required
							/>
						</div>

						<div class="single-input">
							<label class="single-input__label" for="message"
								>Message <span class="text-orange">*</span></label
							>
							<textarea
								class="single-input__field single-input__field--message"
								id="message"
								name="message"
								placeholder="Message"
								required
								rows="8"></textarea>
						</div>

						<button
							class="theme-btn theme-btn-size-lg theme-btn__primary contact__form__btn"
							type="submit">Send</button
						>
					</form>
				</div>
			</section>
			<!-- ==|| Contact Section End ||== -->
		</div>
	</main>
	<!-- =====|| Main Section End ||====== -->
</Layout>

<Footer />
